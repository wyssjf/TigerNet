---
// src/pages/dashboard/attendance.astro
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JRTXCTF | Attendance</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  </head>
  <body>

    <div class="layout">
      <!-- SIDEBAR (same as roster) -->
      <aside class="sidebar">
        <div class="sidebar-brand">
          <i class="fa-solid fa-paw"></i>
          <span>JRTXCTF</span>
        </div>
        <nav class="sidebar-nav">
          <a href="/dashboard/roster" class="nav-item">
            <i class="fa-solid fa-users"></i> Roster
          </a>
          <a href="/dashboard/attendance" class="nav-item active">
            <i class="fa-solid fa-clipboard-check"></i> Attendance
          </a>
        </nav>
        <div class="sidebar-footer">
          <div class="user-info">
            <i class="fa-solid fa-circle-user"></i>
            <span id="userEmail">Loading...</span>
          </div>
          <button class="btn-signout" id="signoutBtn">
            <i class="fa-solid fa-right-from-bracket"></i> Sign Out
          </button>
        </div>
      </aside>

      <!-- MAIN -->
      <main class="main">
        <div class="page-header">
          <div>
            <h1>Attendance</h1>
            <p class="page-sub">Daily practice attendance</p>
          </div>
          <div class="header-actions">
            <input type="date" id="practiceDate" class="date-picker" />
            <div class="filter-wrap">
              <select id="filterTeam">
                <option value="">All Teams</option>
                <option value="Boys">Boys</option>
                <option value="Girls">Girls</option>
              </select>
            </div>
          </div>
        </div>

        <!-- SUMMARY BAR -->
        <div class="summary-bar" id="summaryBar">
          <div class="summary-item">
            <span class="summary-num" id="sumPresent">—</span>
            <span class="summary-label present">Present</span>
          </div>
          <div class="summary-item">
            <span class="summary-num" id="sumLate">—</span>
            <span class="summary-label late">Late</span>
          </div>
          <div class="summary-item">
            <span class="summary-num" id="sumExcused">—</span>
            <span class="summary-label excused">Excused</span>
          </div>
          <div class="summary-item">
            <span class="summary-num" id="sumUnexcused">—</span>
            <span class="summary-label unexcused">Unexcused</span>
          </div>
          <div class="summary-item">
            <span class="summary-num" id="sumUnmarked">—</span>
            <span class="summary-label unmarked">Unmarked</span>
          </div>
        </div>

        <!-- ATTENDANCE TABLE -->
        <div class="table-wrap">
          <table class="attendance-table" id="attendanceTable">
            <thead>
              <tr>
                <th>Athlete</th>
                <th>Team</th>
                <th>Event Group</th>
                <th>Status</th>
                <th>Notes</th>
                <th id="saveAllCol" style="display:none;">
                  <button class="btn-save-all" id="saveAllBtn">
                    <i class="fa-solid fa-floppy-disk"></i> Save All
                  </button>
                </th>
              </tr>
            </thead>
            <tbody id="attendanceBody">
              <tr>
                <td colspan="6" class="loading-cell">
                  <i class="fa-solid fa-paw fa-spin"></i> Loading...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </main>
    </div>

    <script type="module">
      import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';

      (async () => {

      const supabase = createClient(
        'https://kbewlrudpdqmvdsbljen.supabase.co',
        'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtiZXdscnVkcGRxbXZkc2JsamVuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2ODkxNDQsImV4cCI6MjA4OTI2NTE0NH0.RYeII_T640_x4AVrThyYgy3nJcHfHc6iUVkWy2R9GgI'
      );

      // ── Auth guard ───────────────────────────────────────────────────────────
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) { window.location.href = '/dashboard'; }

      const { data: profile } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', session.user.id)
        .single();

      const isCoach   = profile?.role === 'coach';
      const isManager = profile?.role === 'manager';

      document.getElementById('userEmail').textContent = session.user.email;

      // ── Sign out ─────────────────────────────────────────────────────────────
      document.getElementById('signoutBtn').addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/dashboard';
      });

      // ── Date picker — default to today ───────────────────────────────────────
      const datePicker = document.getElementById('practiceDate');
      datePicker.value = new Date().toISOString().split('T')[0];
      datePicker.addEventListener('change', loadAttendance);

      // ── Team filter ──────────────────────────────────────────────────────────
      document.getElementById('filterTeam').addEventListener('change', loadAttendance);

      // ── State ────────────────────────────────────────────────────────────────
      let allAthletes   = [];
      let attendanceMap = {}; // athlete_id → { id, status, notes }
      let pendingChanges = {}; // athlete_id → { status, notes }

      // ── Load athletes ─────────────────────────────────────────────────────────
      const { data: athletes } = await supabase
        .from('registrations')
        .select('id, first_name, last_name, team, event_group, grade')
        .order('last_name', { ascending: true });

      allAthletes = athletes || [];
      await loadAttendance();

      async function loadAttendance() {
        const date      = datePicker.value;
        const teamFilter = document.getElementById('filterTeam').value;

        // Load existing attendance for this date
        const { data: records } = await supabase
          .from('attendance')
          .select('*')
          .eq('practice_date', date);

        attendanceMap = {};
        (records || []).forEach(r => { attendanceMap[r.athlete_id] = r; });
        pendingChanges = {};

        renderTable(teamFilter);
      }

      function renderTable(teamFilter) {
        const tbody   = document.getElementById('attendanceBody');
        const saveCol = document.getElementById('saveAllCol');
        const saveBtn = document.getElementById('saveAllBtn');

        const filtered = allAthletes.filter(a => !teamFilter || a.team === teamFilter);

        if (filtered.length === 0) {
          tbody.innerHTML = `<tr><td colspan="6" class="loading-cell">No athletes found.</td></tr>`;
          return;
        }

        // Show save button for coaches and managers
        saveCol.style.display = '';

        tbody.innerHTML = filtered.map(a => {
          const existing = attendanceMap[a.id];
          const status   = existing?.status || '';
          const notes    = existing?.notes  || '';

          return `
            <tr id="row-${a.id}" class="${status ? 'has-status' : ''}">
              <td class="athlete-cell">
                <div class="athlete-initial">${a.first_name[0]}${a.last_name[0]}</div>
                <div>
                  <div class="athlete-name">${a.last_name}, ${a.first_name}</div>
                  <div class="athlete-grade">Grade ${a.grade}</div>
                </div>
              </td>
              <td><span class="tag ${a.team === 'Boys' ? 'boys' : 'girls'}">${a.team}</span></td>
              <td class="event-cell">${a.event_group || '—'}</td>
              <td>
                <div class="status-btns" data-id="${a.id}">
                  <button class="status-btn present  ${status === 'Present'   ? 'active' : ''}" data-status="Present"   onclick="setStatus('${a.id}', 'Present')">P</button>
                  <button class="status-btn late     ${status === 'Late'      ? 'active' : ''}" data-status="Late"      onclick="setStatus('${a.id}', 'Late')">L</button>
                  <button class="status-btn excused  ${status === 'Excused'   ? 'active' : ''}" data-status="Excused"   onclick="setStatus('${a.id}', 'Excused')">E</button>
                  <button class="status-btn unexcused ${status === 'Unexcused' ? 'active' : ''}" data-status="Unexcused" onclick="setStatus('${a.id}', 'Unexcused')">U</button>
                </div>
              </td>
              <td>
                <input
                  class="notes-input"
                  type="text"
                  placeholder="Add note..."
                  value="${notes}"
                  data-id="${a.id}"
                  onchange="setNotes('${a.id}', this.value)"
                />
              </td>
              <td></td>
            </tr>
          `;
        }).join('');

        updateSummary(filtered);
      }

      window.setStatus = (athleteId, status) => {
        if (!pendingChanges[athleteId]) pendingChanges[athleteId] = {};
        pendingChanges[athleteId].status = status;

        // Update button UI
        const btns = document.querySelectorAll(`.status-btns[data-id="${athleteId}"] .status-btn`);
        btns.forEach(btn => btn.classList.toggle('active', btn.dataset.status === status));

        // Show unsaved indicator
        const row = document.getElementById(`row-${athleteId}`);
        if (row) row.classList.add('has-pending');

        updateSummary(allAthletes.filter(a => !document.getElementById('filterTeam').value || a.team === document.getElementById('filterTeam').value));
      };

      window.setNotes = (athleteId, notes) => {
        if (!pendingChanges[athleteId]) pendingChanges[athleteId] = {};
        pendingChanges[athleteId].notes = notes;
        const row = document.getElementById(`row-${athleteId}`);
        if (row) row.classList.add('has-pending');
      };

      // ── Save all ──────────────────────────────────────────────────────────────
      document.getElementById('saveAllBtn').addEventListener('click', async () => {
        const btn  = document.getElementById('saveAllBtn');
        const date = datePicker.value;

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

        const upserts = Object.entries(pendingChanges).map(([athleteId, changes]) => {
          const existing = attendanceMap[athleteId];
          return {
            ...(existing ? { id: existing.id } : {}),
            practice_date: date,
            athlete_id:    athleteId,
            status:        changes.status || existing?.status || 'Present',
            notes:         changes.notes  !== undefined ? changes.notes : (existing?.notes || null),
          };
        });

        if (upserts.length === 0) {
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save All';
          return;
        }

        const { error } = await supabase
          .from('attendance')
          .upsert(upserts, { onConflict: 'practice_date,athlete_id' });

        if (error) {
          alert('Error saving: ' + error.message);
        } else {
          // Merge pending into attendanceMap
          upserts.forEach(u => { attendanceMap[u.athlete_id] = { ...attendanceMap[u.athlete_id], ...u }; });
          pendingChanges = {};
          document.querySelectorAll('.has-pending').forEach(r => r.classList.remove('has-pending'));
        }

        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save All';
      });

      // ── Summary ───────────────────────────────────────────────────────────────
      function updateSummary(filtered) {
        const counts = { Present: 0, Late: 0, Excused: 0, Unexcused: 0, unmarked: 0 };
        filtered.forEach(a => {
          const pending = pendingChanges[a.id]?.status;
          const status  = pending || attendanceMap[a.id]?.status;
          if (!status) counts.unmarked++;
          else counts[status] = (counts[status] || 0) + 1;
        });

        document.getElementById('sumPresent').textContent   = counts.Present;
        document.getElementById('sumLate').textContent      = counts.Late;
        document.getElementById('sumExcused').textContent   = counts.Excused;
        document.getElementById('sumUnexcused').textContent = counts.Unexcused;
        document.getElementById('sumUnmarked').textContent  = counts.unmarked;
      }

      })(); // end async IIFE
    </script>
  </body>
</html>

<style>
  :root {
    --navy:      #0033A0;
    --orange:    #FF6700;
    --text:      #0f172a;
    --muted:     #64748b;
    --border:    #e2e8f0;
    --bg:        #f1f5f9;
    --white:     #ffffff;
    --sidebar-w: 220px;
    --font:      'DM Sans', system-ui, sans-serif;

    --present:   #16a34a;
    --late:      #d97706;
    --excused:   #2563eb;
    --unexcused: #dc2626;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Layout / Sidebar (same as roster) ─────────────────────────────────── */
  .layout { display: flex; min-height: 100vh; }

  .sidebar {
    width: var(--sidebar-w);
    background: var(--navy);
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
  }

  .sidebar-brand {
    display: flex; align-items: center; gap: 0.6rem;
    color: white; font-size: 0.95rem; font-weight: 700; letter-spacing: 1.5px;
    padding: 0 0.5rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    margin-bottom: 1.5rem;
  }
  .sidebar-brand i { color: var(--orange); font-size: 1.2rem; }

  .sidebar-nav { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }

  .nav-item {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.65rem 0.75rem; border-radius: 8px;
    color: rgba(255,255,255,0.65); text-decoration: none;
    font-size: 0.9rem; font-weight: 500; transition: all 0.15s ease;
  }
  .nav-item:hover  { background: rgba(255,255,255,0.1); color: white; }
  .nav-item.active { background: rgba(255,255,255,0.15); color: white; }
  .nav-item i { width: 16px; text-align: center; }

  .sidebar-footer {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: 1rem;
    display: flex; flex-direction: column; gap: 0.75rem;
  }
  .user-info {
    display: flex; align-items: center; gap: 0.5rem;
    color: rgba(255,255,255,0.6); font-size: 0.78rem; overflow: hidden;
  }
  .user-info span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .btn-signout {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px; color: rgba(255,255,255,0.7);
    font-size: 0.82rem; font-family: var(--font); cursor: pointer;
    transition: all 0.15s ease;
  }
  .btn-signout:hover { background: rgba(255,255,255,0.15); color: white; }

  /* ── Main ───────────────────────────────────────────────────────────────── */
  .main {
    margin-left: var(--sidebar-w);
    flex: 1;
    padding: 2rem 2.5rem;
  }

  .page-header {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap; gap: 1rem;
  }

  h1 { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; }
  .page-sub { color: var(--muted); font-size: 0.9rem; margin-top: 0.2rem; }

  .header-actions { display: flex; gap: 0.75rem; align-items: center; }

  .date-picker, .filter-wrap select {
    padding: 0.6rem 0.9rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-size: 0.875rem;
    font-family: var(--font);
    color: var(--text);
    background: var(--white);
    outline: none;
    transition: border-color 0.15s;
  }
  .date-picker:focus, .filter-wrap select:focus { border-color: var(--orange); }

  /* ── Summary bar ────────────────────────────────────────────────────────── */
  .summary-bar {
    display: flex; gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .summary-item {
    flex: 1; background: var(--white);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 0.9rem 0.5rem;
    gap: 0.2rem;
  }

  .summary-num { font-size: 1.5rem; font-weight: 700; color: var(--text); }

  .summary-label {
    font-size: 0.7rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .summary-label.present   { color: var(--present); }
  .summary-label.late      { color: var(--late); }
  .summary-label.excused   { color: var(--excused); }
  .summary-label.unexcused { color: var(--unexcused); }
  .summary-label.unmarked  { color: var(--muted); }

  /* ── Table ──────────────────────────────────────────────────────────────── */
  .table-wrap {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .attendance-table {
    width: 100%;
    border-collapse: collapse;
  }

  .attendance-table thead {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .attendance-table th {
    padding: 0.75rem 1rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    text-align: left;
    white-space: nowrap;
  }

  .attendance-table td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--bg);
    font-size: 0.875rem;
    vertical-align: middle;
  }

  .attendance-table tr:last-child td { border-bottom: none; }

  .attendance-table tr.has-pending { background: #fffbeb; }

  .loading-cell { text-align: center; color: var(--muted); padding: 3rem; }

  /* Athlete cell */
  .athlete-cell { display: flex; align-items: center; gap: 0.75rem; }
  .athlete-initial {
    width: 32px; height: 32px; border-radius: 8px;
    background: var(--navy); color: white;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.72rem; font-weight: 700; flex-shrink: 0;
  }
  .athlete-name { font-weight: 600; color: var(--text); }
  .athlete-grade { font-size: 0.75rem; color: var(--muted); }
  .event-cell { color: var(--muted); font-size: 0.82rem; }

  /* Tags */
  .tag {
    font-size: 0.7rem; font-weight: 600;
    padding: 0.2rem 0.5rem; border-radius: 4px;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .tag.boys  { background: #dbeafe; color: #1d4ed8; }
  .tag.girls { background: #fce7f3; color: #be185d; }

  /* Status buttons */
  .status-btns { display: flex; gap: 0.3rem; }

  .status-btn {
    width: 28px; height: 28px;
    border-radius: 6px;
    border: 1.5px solid var(--border);
    background: var(--bg);
    font-size: 0.72rem;
    font-weight: 700;
    font-family: var(--font);
    cursor: pointer;
    color: var(--muted);
    transition: all 0.12s ease;
  }

  .status-btn:hover { border-color: var(--muted); color: var(--text); }

  .status-btn.present.active   { background: #dcfce7; border-color: var(--present);   color: var(--present); }
  .status-btn.late.active      { background: #fef3c7; border-color: var(--late);      color: var(--late); }
  .status-btn.excused.active   { background: #dbeafe; border-color: var(--excused);   color: var(--excused); }
  .status-btn.unexcused.active { background: #fee2e2; border-color: var(--unexcused); color: var(--unexcused); }

  /* Notes input */
  .notes-input {
    width: 100%;
    padding: 0.4rem 0.6rem;
    border: 1.5px solid transparent;
    border-radius: 6px;
    font-size: 0.82rem;
    font-family: var(--font);
    color: var(--text);
    background: transparent;
    outline: none;
    transition: all 0.15s;
  }
  .notes-input:focus { border-color: var(--border); background: var(--bg); }
  .notes-input::placeholder { color: var(--border); }

  /* Save all button */
  .btn-save-all {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    background: var(--navy); color: white;
    border: none; border-radius: 6px;
    font-size: 0.8rem; font-weight: 600;
    font-family: var(--font); cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .btn-save-all:hover    { background: #002280; }
  .btn-save-all:disabled { opacity: 0.6; cursor: not-allowed; }
</style>