---
// src/pages/dashboard/attendance.astro
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>JRTXCTF | Attendance</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
</head>
<body>
<div class="bg-mesh"></div>

<div class="mobile-topbar">
  <div class="mobile-brand"><i class="fa-solid fa-paw" style="color:#FF6700"></i> JRTXCTF</div>
  <button class="hamburger" onclick="openDrawer()"><i class="fa-solid fa-bars"></i></button>
</div>
<div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

<div class="layout">
  <aside class="sidebar" id="sidebar">
    <div class="sb-brand">
      <i class="fa-solid fa-paw" style="color:#FF6700;font-size:20px;"></i>
      <div>
        <div class="sb-name">JRTXCTF</div>
        <div class="sb-sub">Tiger Net</div>
      </div>
    </div>
    <div class="sb-section">PROGRAM</div>
    <nav class="sb-nav">
      <a href="/dashboard/roster" class="nav-item"><i class="fa-solid fa-users nav-icon"></i> Roster</a>
      <a href="/dashboard/attendance" class="nav-item active"><i class="fa-solid fa-calendar-check nav-icon"></i> Attendance</a>
    </nav>
    <div class="sb-foot">
      <div class="user-chip">
        <div class="user-av" id="userAv">?</div>
        <span class="user-em" id="userEmail">Loading...</span>
      </div>
      <button class="signout-btn" id="signoutBtn"><i class="fa-solid fa-right-from-bracket"></i> Sign out</button>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <h1>Attendance</h1>
        <span class="page-meta">Daily practice log</span>
      </div>
      <div class="topbar-right">
        <input type="date" id="practiceDate" class="date-picker" />
        <select id="filterTeam" class="team-filter">
          <option value="">All Teams</option>
          <option value="Boys">Boys</option>
          <option value="Girls">Girls</option>
        </select>
      </div>
    </div>

    <div class="summary-bar" id="summaryBar">
      <div class="sum-item"><span class="sum-num" id="sumPresent">—</span><span class="sum-label present">Present</span></div>
      <div class="sum-item"><span class="sum-num" id="sumLate">—</span><span class="sum-label late">Late</span></div>
      <div class="sum-item"><span class="sum-num" id="sumExcused">—</span><span class="sum-label excused">Excused</span></div>
      <div class="sum-item"><span class="sum-num" id="sumUnexcused">—</span><span class="sum-label unexcused">Unexcused</span></div>
      <div class="sum-item"><span class="sum-num" id="sumUnmarked">—</span><span class="sum-label unmarked">Unmarked</span></div>
      <button class="btn-save-all" id="saveAllBtn"><i class="fa-solid fa-floppy-disk"></i> Save All</button>
    </div>

    <div class="att-list" id="attBody">
      <div class="loading-cell"><i class="fa-solid fa-paw fa-spin"></i> Loading...</div>
    </div>
  </main>
</div>

<button class="save-float hidden" id="saveFloat" onclick="document.getElementById('saveAllBtn').click()">
  <i class="fa-solid fa-floppy-disk"></i> Save
</button>

<script type="module">
import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';
(async () => {
const supabase = createClient(
  'https://kbewlrudpdqmvdsbljen.supabase.co',
  'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtiZXdscnVkcGRxbXZkc2JsamVuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2ODkxNDQsImV4cCI6MjA4OTI2NTE0NH0.RYeII_T640_x4AVrThyYgy3nJcHfHc6iUVkWy2R9GgI'
);

const EV_COLOR = { Sprints:'ev-sp', Distance:'ev-di', Throws:'ev-th' };

const { data: { session } } = await supabase.auth.getSession();
if (!session) { window.location.href = '/dashboard'; return; }

const email = session.user.email;
document.getElementById('userEmail').textContent = email;
document.getElementById('userAv').textContent = email.slice(0,2).toUpperCase();

window.openDrawer  = () => { document.getElementById('sidebar').classList.add('open'); document.getElementById('drawerOverlay').classList.add('visible'); document.body.style.overflow='hidden'; };
window.closeDrawer = () => { document.getElementById('sidebar').classList.remove('open'); document.getElementById('drawerOverlay').classList.remove('visible'); document.body.style.overflow=''; };
document.getElementById('signoutBtn').addEventListener('click', async () => { await supabase.auth.signOut(); window.location.href = '/dashboard'; });

const datePicker = document.getElementById('practiceDate');
datePicker.value = new Date().toISOString().split('T')[0];
datePicker.addEventListener('change', loadAttendance);
document.getElementById('filterTeam').addEventListener('change', () => renderList(allAthletes.filter(teamFilter)));

let allAthletes = [];
let attendanceMap = {};
let pendingChanges = {};

const { data: athletes } = await supabase.from('registrations').select('id,first_name,last_name,team,event_group,grade').order('last_name');
allAthletes = athletes || [];
await loadAttendance();

function teamFilter(a) {
  const tf = document.getElementById('filterTeam').value;
  return !tf || a.team === tf;
}

async function loadAttendance() {
  const date = datePicker.value;
  const { data: records } = await supabase.from('attendance').select('*').eq('practice_date', date);
  attendanceMap = {};
  (records || []).forEach(r => { attendanceMap[r.athlete_id] = r; });
  pendingChanges = {};
  renderList(allAthletes.filter(teamFilter));
}

const EV_COLOR = { Sprints:'ev-sp', Distance:'ev-di', Throws:'ev-th' };

function renderList(athletes) {
  const body = document.getElementById('attBody');
  if (!athletes.length) { body.innerHTML = '<div class="loading-cell">No athletes found.</div>'; return; }

  body.innerHTML = athletes.map(a => {
    const cur = pendingChanges[a.id]?.status || attendanceMap[a.id]?.status || '';
    const note = pendingChanges[a.id]?.notes !== undefined ? pendingChanges[a.id].notes : (attendanceMap[a.id]?.notes || '');
    const pending = pendingChanges[a.id] ? 'pending' : '';
    return `<div class="att-row ${pending}" id="row-${a.id}">
      <div class="att-av ${EV_COLOR[a.event_group]||'ev-def'}">${a.first_name[0]}${a.last_name[0]}</div>
      <div class="att-name">${a.first_name} ${a.last_name}<span class="att-grade">Gr. ${a.grade}</span></div>
      <div class="att-btns" id="att-${a.id}">
        ${['Present','Late','Excused','Unexcused'].map((s,i) => {
          const labels = ['P','L','E','U'];
          const cls = cur === s ? `att-btn-active att-${s.toLowerCase()}` : '';
          return `<button class="att-btn ${cls}" onclick="markStatus('${a.id}','${s}')">${labels[i]}</button>`;
        }).join('')}
      </div>
      <input class="att-note" type="text" placeholder="Note..." value="${note}" onchange="setNote('${a.id}',this.value)" />
    </div>`;
  }).join('');
  updateSummary(athletes);
}

window.markStatus = (id, status) => {
  if (!pendingChanges[id]) pendingChanges[id] = {};
  const prev = pendingChanges[id].status || attendanceMap[id]?.status;
  pendingChanges[id].status = prev === status ? null : status;
  document.getElementById(`row-${id}`).classList.add('pending');

  const btns = document.getElementById(`att-${id}`);
  const cur = pendingChanges[id].status;
  btns.innerHTML = ['Present','Late','Excused','Unexcused'].map((s,i) => {
    const labels = ['P','L','E','U'];
    const cls = cur === s ? `att-btn-active att-${s.toLowerCase()}` : '';
    return `<button class="att-btn ${cls}" onclick="markStatus('${id}','${s}')">${labels[i]}</button>`;
  }).join('');
  updateSummary(allAthletes.filter(teamFilter));
};

window.setNote = (id, notes) => {
  if (!pendingChanges[id]) pendingChanges[id] = {};
  pendingChanges[id].notes = notes;
  document.getElementById(`row-${id}`).classList.add('pending');
};

document.getElementById('saveAllBtn').addEventListener('click', async () => {
  const btn = document.getElementById('saveAllBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
  const date = datePicker.value;
  const upserts = Object.entries(pendingChanges).map(([athleteId, changes]) => {
    const existing = attendanceMap[athleteId];
    return {
      ...(existing ? { id: existing.id } : {}),
      practice_date: date, athlete_id: athleteId,
      status: changes.status || existing?.status || 'Present',
      notes: changes.notes !== undefined ? changes.notes : (existing?.notes || null),
    };
  }).filter(u => u.status);
  if (upserts.length) {
    const { error } = await supabase.from('attendance').upsert(upserts, { onConflict: 'practice_date,athlete_id' });
    if (!error) {
      upserts.forEach(u => { attendanceMap[u.athlete_id] = { ...attendanceMap[u.athlete_id], ...u }; });
      pendingChanges = {};
      document.querySelectorAll('.att-row.pending').forEach(r => r.classList.remove('pending'));
    }
  }
  btn.disabled = false;
  btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save All';
});

function updateSummary(athletes) {
  const counts = { Present:0, Late:0, Excused:0, Unexcused:0, unmarked:0 };
  athletes.forEach(a => {
    const s = pendingChanges[a.id]?.status || attendanceMap[a.id]?.status;
    if (!s) counts.unmarked++; else counts[s] = (counts[s]||0)+1;
  });
  document.getElementById('sumPresent').textContent   = counts.Present;
  document.getElementById('sumLate').textContent      = counts.Late;
  document.getElementById('sumExcused').textContent   = counts.Excused;
  document.getElementById('sumUnexcused').textContent = counts.Unexcused;
  document.getElementById('sumUnmarked').textContent  = counts.unmarked;
}

// Mobile float button
if (window.innerWidth <= 768) document.getElementById('saveFloat').classList.remove('hidden');
window.addEventListener('resize', () => {
  document.getElementById('saveFloat').classList.toggle('hidden', window.innerWidth > 768);
});
})();
</script>
</body>
</html>

<style is:global>
:root {
  --primary-blue: #0033A0;
  --accent-orange: #FF6700;
  --accent-orange-hover: #e65c00;
  --bg-dark: #020617;
  --card-bg: rgba(15, 23, 42, 0.75);
  --text-main: #f8fafc;
  --text-muted: #94a3b8;
  --border-light: rgba(255, 255, 255, 0.12);
  --input-bg: rgba(255, 255, 255, 0.05);
  --focus-ring: rgba(255, 103, 0, 0.4);
  --font-ui: 'Inter', system-ui, sans-serif;
  --sidebar-w: 220px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font-ui); background: var(--bg-dark); color: var(--text-main); min-height: 100vh; -webkit-font-smoothing: antialiased; }
.bg-mesh { position: fixed; inset: 0; z-index: -1; background: linear-gradient(-45deg, #020617, #0f172a, var(--primary-blue), #020617); background-size: 400% 400%; background-position: 0% 50%; }

.layout { display: flex; min-height: 100vh; }
.sidebar { width: var(--sidebar-w); background: rgba(2,6,23,0.9); backdrop-filter: blur(24px); border-right: 1px solid var(--border-light); display: flex; flex-direction: column; padding: 1.5rem 1rem; position: fixed; top:0;left:0;bottom:0;z-index:100; }
.sb-brand { display: flex; align-items: center; gap: 10px; padding-bottom: 1.25rem; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border-light); }
.sb-name { color: white; font-size: 13px; font-weight: 700; letter-spacing: 1.5px; }
.sb-sub  { color: var(--text-muted); font-size: 10px; }
.sb-section { font-size: 9px; color: rgba(255,255,255,0.3); letter-spacing: 2px; padding: 0.75rem 0.5rem 0.3rem; }
.sb-nav { display: flex; flex-direction: column; gap: 2px; flex: 1; }
.nav-item { display: flex; align-items: center; gap: 10px; padding: 0.6rem 0.75rem; border-radius: 10px; color: var(--text-muted); font-size: 13px; text-decoration: none;  }
.nav-item:hover  { background: rgba(255,255,255,0.06); color: white; }
.nav-item.active { background: rgba(255,103,0,0.15); color: var(--accent-orange); border: 1px solid rgba(255,103,0,0.2); }
.nav-icon { width: 16px; text-align: center; }
.sb-foot { border-top: 1px solid var(--border-light); padding-top: 1rem; display: flex; flex-direction: column; gap: 8px; }
.user-chip { display: flex; align-items: center; gap: 8px; padding: 0.4rem 0.5rem; background: var(--input-bg); border-radius: 8px; }
.user-av { width: 24px; height: 24px; border-radius: 50%; background: var(--accent-orange); color: white; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; flex-shrink: 0; }
.user-em { font-size: 10px; color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.signout-btn { display: flex; align-items: center; gap: 6px; padding: 0.5rem 0.75rem; background: var(--input-bg); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-muted); font-size: 12px; font-family: var(--font-ui); cursor: pointer;  }
.signout-btn:hover { background: rgba(255,255,255,0.08); color: white; }
.main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; }
.topbar { background: rgba(2,6,23,0.8); backdrop-filter: blur(24px); border-bottom: 1px solid var(--border-light); padding: 0 1.5rem; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top:0; z-index:10; }
.topbar-left { display: flex; align-items: baseline; gap: 10px; }
.topbar h1 { font-size: 18px; font-weight: 700; color: white; letter-spacing: -0.02em; }
.page-meta { font-size: 12px; color: var(--text-muted); }
.topbar-right { display: flex; gap: 8px; align-items: center; }
.date-picker, .team-filter { padding: 0.5rem 0.75rem; border: 1px solid var(--border-light); border-radius: 8px; font-size: 12px; font-family: var(--font-ui); background: var(--input-bg); color: var(--text-main); outline: none; }
.date-picker:focus, .team-filter:focus { border-color: var(--accent-orange); }
.date-picker::-webkit-calendar-picker-indicator { filter: invert(1); }
.team-filter option { background: #0f172a; }
.summary-bar { background: rgba(15,23,42,0.6); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-light); padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 1px; }
.sum-item { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 0.5rem; }
.sum-num { font-size: 1.5rem; font-weight: 700; color: white; }
.sum-label { font-size: 9px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-top: 2px; }
.sum-label.present   { color: #4ade80; }
.sum-label.late      { color: #fbbf24; }
.sum-label.excused   { color: #818cf8; }
.sum-label.unexcused { color: #f87171; }
.sum-label.unmarked  { color: var(--text-muted); }
.btn-save-all { display: flex; align-items: center; gap: 6px; padding: 0.6rem 1.25rem; background: var(--accent-orange); color: white; border: none; border-radius: 20px; font-size: 12px; font-weight: 700; font-family: var(--font-ui); cursor: pointer; margin-left: auto;   }
.btn-save-all:hover { background: var(--accent-orange-hover);  }
.btn-save-all:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.att-list { padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 6px; }
.loading-cell { text-align: center; color: var(--text-muted); padding: 3rem; font-size: 13px; }
.att-row { background: var(--card-bg); backdrop-filter: blur(12px); border: 1px solid var(--border-light); border-radius: 12px; padding: 10px 16px; display: flex; align-items: center; gap: 12px;  }
.att-row.pending { border-color: rgba(255,103,0,0.4); background: rgba(255,103,0,0.05); }
.att-av { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; font-family: monospace; }
.ev-sp  { background: rgba(250,238,218,0.15); color: #fbbf24; }
.ev-di  { background: rgba(225,245,238,0.15); color: #34d399; }
.ev-th  { background: rgba(250,236,231,0.15); color: #f87171; }
.ev-def { background: rgba(238,237,254,0.15); color: #a78bfa; }
.att-name { font-size: 13px; font-weight: 600; color: white; min-width: 160px; display: flex; align-items: center; gap: 8px; }
.att-grade { font-size: 11px; color: var(--text-muted); font-weight: 400; }
.att-btns { display: flex; gap: 4px; flex-shrink: 0; }
.att-btn { width: 34px; height: 34px; border-radius: 8px; border: 1px solid var(--border-light); background: var(--input-bg); font-size: 11px; font-weight: 700; font-family: var(--font-ui); cursor: pointer; color: var(--text-muted); display: flex; align-items: center; justify-content: center; transition: all 0.12s; }
.att-btn:hover {  }
.att-btn-active { font-weight: 800; }
.att-present   { background: rgba(74,222,128,0.15); border-color: #4ade80; color: #4ade80; }
.att-late      { background: rgba(251,191,36,0.15); border-color: #fbbf24; color: #fbbf24; }
.att-excused   { background: rgba(129,140,248,0.15); border-color: #818cf8; color: #818cf8; }
.att-unexcused { background: rgba(248,113,113,0.15); border-color: #f87171; color: #f87171; }
.att-note { flex: 1; padding: 0.4rem 0.75rem; border: 1px solid var(--border-light); border-radius: 6px; font-size: 12px; font-family: var(--font-ui); background: var(--input-bg); color: var(--text-main); outline: none;  }
.att-note:focus { border-color: var(--accent-orange); }
.att-note::placeholder { color: rgba(148,163,184,0.4); }
.save-float { position: fixed; bottom: 1.5rem; right: 1.5rem; display: flex; align-items: center; gap: 6px; padding: 0.85rem 1.5rem; background: var(--accent-orange); color: white; border: none; border-radius: 30px; font-size: 13px; font-weight: 700; font-family: var(--font-ui); cursor: pointer;  z-index: 50; }
.save-float.hidden { display: none; }
.mobile-topbar { display: none; position: fixed; top:0;left:0;right:0; z-index:200; background: rgba(2,6,23,0.95); backdrop-filter: blur(24px); border-bottom: 1px solid var(--border-light); padding: 0 1.25rem; height: 56px; align-items: center; justify-content: space-between; }
.mobile-brand { display: flex; align-items: center; gap: 8px; color: white; font-size: 13px; font-weight: 700; letter-spacing: 1.5px; }
.hamburger { background: none; border: none; color: var(--text-muted); font-size: 18px; cursor: pointer; }
.drawer-overlay { display: none; position: fixed; inset:0; z-index:99; background: rgba(2,6,23,0.7); backdrop-filter: blur(4px); }
.drawer-overlay.visible { display: block; }
@media (max-width: 768px) {
  .mobile-topbar { display: flex; }
  .sidebar { transform: translateX(-100%); transition: transform 0.25s ease; top:0; z-index:300; }
  .sidebar.open { transform: translateX(0); }
  .main { margin-left: 0; padding-top: 56px; }
  .topbar { top: 56px; flex-direction: column; height: auto; padding: 0.75rem 1rem; gap: 0.5rem; align-items: flex-start; }
  .topbar-right { width: 100%; }
  .att-list { padding: 0.75rem; }
  .att-row { flex-wrap: wrap; }
  .att-note { width: 100%; }
  .btn-save-all { display: none; }
}
</style>