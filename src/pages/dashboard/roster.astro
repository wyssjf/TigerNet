---
// src/pages/dashboard/roster.astro
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>JRTXCTF | Roster</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
</head>
<body>
<div class="bg-mesh"></div>

<div class="mobile-topbar">
  <div class="mobile-brand"><i class="fa-solid fa-paw" style="color:#FF6700"></i> JRTXCTF</div>
  <button class="hamburger" onclick="openDrawer()"><i class="fa-solid fa-bars"></i></button>
</div>
<div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

<div class="layout">
  <aside class="sidebar" id="sidebar">
    <div class="sb-brand">
      <i class="fa-solid fa-paw" style="color:#FF6700;font-size:20px;"></i>
      <div>
        <div class="sb-name">JRTXCTF</div>
        <div class="sb-sub">Tiger Net</div>
      </div>
    </div>
    <div class="sb-section">PROGRAM</div>
    <nav class="sb-nav">
      <a href="/dashboard/roster" class="nav-item active"><i class="fa-solid fa-users nav-icon"></i> Roster</a>
      <a href="/dashboard/attendance" class="nav-item"><i class="fa-solid fa-calendar-check nav-icon"></i> Attendance</a>
    </nav>
    <div class="sb-foot">
      <div class="user-chip">
        <div class="user-av" id="userAv">?</div>
        <span class="user-em" id="userEmail">Loading...</span>
      </div>
      <button class="signout-btn" id="signoutBtn"><i class="fa-solid fa-right-from-bracket"></i> Sign out</button>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <h1>Roster</h1>
        <span class="page-meta" id="rosterCount">—</span>
      </div>
      <div class="topbar-right">
        <button class="tbtn" id="importBtn"><i class="fa-solid fa-file-arrow-up"></i> Import</button>
        <button class="tbtn" id="addAthleteBtn"><i class="fa-solid fa-user-plus"></i> Add</button>
        <button class="tbtn accent" id="exportBtn"><i class="fa-solid fa-download"></i> Export</button>
      </div>
    </div>

    <div class="filter-bar">
      <button class="fpill active" onclick="setFilter(this,'all')">All</button>
      <div class="fsep"></div>
      <button class="fpill" onclick="setFilter(this,'team:Boys')">Boys</button>
      <button class="fpill" onclick="setFilter(this,'team:Girls')">Girls</button>
      <div class="fsep"></div>
      <button class="fpill" onclick="setFilter(this,'status:Active')">Active</button>
      <button class="fpill" onclick="setFilter(this,'status:Suspended')">Suspended</button>
      <button class="fpill" onclick="setFilter(this,'status:Ineligible')">Ineligible</button>
      <button class="fpill" onclick="setFilter(this,'status:Cut')">Cut</button>
      <div class="fsep"></div>
      <button class="fpill" onclick="setFilter(this,'season:Cross Country')">XC</button>
      <button class="fpill" onclick="setFilter(this,'season:Indoor Track & Field')">Indoor</button>
      <button class="fpill" onclick="setFilter(this,'season:Outdoor Track & Field')">Outdoor</button>
      <div class="fsep"></div>
      <button class="fpill" onclick="setFilter(this,'paperwork:No Physical')">No Physical</button>
      <button class="fpill" onclick="setFilter(this,'paperwork:Missing Docs')">Missing Docs</button>
      <div class="search-wrap"><i class="fa-solid fa-magnifying-glass"></i><input type="text" id="searchInput" placeholder="Search..." /></div>
    </div>

    <div class="flight-wrap">
      <div class="flight-list" id="rosterBody">
        <div class="loading-cell"><i class="fa-solid fa-paw fa-spin"></i> Loading...</div>
      </div>
    </div>
  </main>
</div>

<!-- ADD / EDIT MODAL -->
<div class="overlay hidden" id="athleteFormOverlay">
  <div class="modal modal-form">
    <div class="modal-hd">
      <div><div class="modal-title" id="formModalTitle">Add Athlete</div><div class="modal-sub" id="formModalSub">Manually add to roster</div></div>
      <button class="modal-x" onclick="closeAthleteForm()"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-section-label">Athlete Details</div>
      <div class="frow">
        <div class="fg"><label>First Name *</label><input type="text" id="f_fn" /></div>
        <div class="fg"><label>Last Name *</label><input type="text" id="f_ln" /></div>
      </div>
      <div class="frow">
        <div class="fg"><label>Grade *</label><select id="f_gr"><option value="">—</option><option value="9">9th</option><option value="10">10th</option><option value="11">11th</option><option value="12">12th</option></select></div>
        <div class="fg"><label>Birthday</label><input type="date" id="f_bday" /></div>
      </div>
      <div class="frow">
        <div class="fg"><label>Email *</label><input type="email" id="f_em" placeholder="athlete@example.com" /></div>
        <div class="fg"><label>Phone *</label><input type="tel" id="f_ph" placeholder="(555) 555-5555" /></div>
      </div>
      <div class="frow">
        <div class="fg"><label>Team *</label><select id="f_tm"><option value="">—</option><option>Boys</option><option>Girls</option></select></div>
        <div class="fg"><label>Athlete Type *</label><select id="f_type"><option value="New Athlete">New Athlete</option><option value="Returning Athlete">Returning Athlete</option></select></div>
      </div>
      <div class="form-section-label">Season & Events</div>
      <div class="fg"><label>Season(s) *</label>
        <div class="check-row">
          <label class="ck"><input type="checkbox" name="f_s" value="Cross Country" /> Cross Country</label>
          <label class="ck"><input type="checkbox" name="f_s" value="Indoor Track & Field" /> Indoor T&F</label>
          <label class="ck"><input type="checkbox" name="f_s" value="Outdoor Track & Field" /> Outdoor T&F</label>
        </div>
      </div>
      <div class="frow">
        <div class="fg"><label>Event Group</label><select id="f_ev"><option value="">—</option><option>Sprints</option><option>Distance</option><option>Throws</option></select></div>
        <div class="fg"><label>Sprint Add-ons</label><div class="check-row" style="margin-top:6px;"><label class="ck"><input type="checkbox" name="f_sa" value="Hurdles" /> Hurdles</label><label class="ck"><input type="checkbox" name="f_sa" value="Jumps" /> Jumps</label></div></div>
      </div>
      <div class="form-section-label">Academic</div>
      <div class="fg"><label>Middle School *</label><select id="f_ms"><option value="">Select...</option><option value="Brookland Middle">Brookland Middle</option><option value="Elko Middle">Elko Middle</option><option value="Fairfield Middle">Fairfield Middle</option><option value="George H. Moody Middle">George H. Moody Middle</option><option value="Holman Middle">Holman Middle</option><option value="Hungary Creek Middle">Hungary Creek Middle</option><option value="L. Douglas Wilder Middle">L. Douglas Wilder Middle</option><option value="Pocohontas Middle">Pocohontas Middle</option><option value="Quioccasin Middle">Quioccasin Middle</option><option value="John Rolfe Middle">John Rolfe Middle</option><option value="Short Pump Middle">Short Pump Middle</option><option value="Tuckahoe Middle">Tuckahoe Middle</option><option value="Other">Other</option></select></div>
      <div class="fg hidden" id="f_ms_other_wrap"><label>Other Middle School *</label><input type="text" id="f_ms_other" placeholder="School name" /></div>
      <div class="frow">
        <div class="fg"><label>Specialty Center?</label><select id="f_spec"><option value="no">No</option><option value="yes">Yes</option></select></div>
        <div class="fg hidden" id="f_spec_prog_wrap"><label>Program</label><select id="f_spec_prog"><option value="">Select...</option><option value="Advance College Academy">Advance College Academy</option><option value="International Baccalaureate">International Baccalaureate</option><option value="Spanish Language Immersion">Spanish Language Immersion</option></select></div>
      </div>
      <div class="form-section-label">Prior Activities</div>
      <div class="fg"><label>Other activities this year?</label><select id="f_hact"><option value="no">No</option><option value="yes">Yes</option></select></div>
      <div class="fg hidden" id="f_activities_wrap"><label>Select all that apply</label>
        <div class="activities-grid">
          <label class="ck"><input type="checkbox" name="f_act" value="Basketball" /> Basketball</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Competition Cheer" /> Competition Cheer</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Dance Team" /> Dance Team</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Debate" /> Debate</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Field Hockey" /> Field Hockey</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Football" /> Football</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Forensics" /> Forensics</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Golf" /> Golf</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Gymnastics" /> Gymnastics</label>
          <label class="ck"><input type="checkbox" name="f_act" value="JROTC" /> JROTC</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Marching Band" /> Marching Band</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Sideline Cheer" /> Sideline Cheer</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Step Team" /> Step Team</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Swim" /> Swim</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Volleyball" /> Volleyball</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Wrestling" /> Wrestling</label>
        </div>
      </div>
      <div class="form-section-label">Parent / Guardian</div>
      <div class="fg"><label>Parent 1 Name *</label><input type="text" id="f_p1n" /></div>
      <div class="frow">
        <div class="fg"><label>Parent 1 Phone *</label><input type="tel" id="f_p1p" placeholder="(555) 555-5555" /></div>
        <div class="fg"><label>Parent 1 Email *</label><input type="email" id="f_p1e" placeholder="parent@example.com" /></div>
      </div>
      <div class="fg"><label class="ck" style="text-transform:none;letter-spacing:normal;font-weight:500;"><input type="checkbox" id="f_add_p2" onchange="toggleP2()" /> Add second parent / guardian</label></div>
      <div class="hidden" id="f_p2_wrap">
        <div class="fg"><label>Parent 2 Name</label><input type="text" id="f_p2n" /></div>
        <div class="frow">
          <div class="fg"><label>Parent 2 Phone</label><input type="tel" id="f_p2p" placeholder="(555) 555-5555" /></div>
          <div class="fg"><label>Parent 2 Email</label><input type="email" id="f_p2e" placeholder="parent@example.com" /></div>
        </div>
      </div>
      <div class="form-section-label">Notes</div>
      <div class="fg"><label>Additional Information <span style="font-weight:400;color:var(--text-muted)">(optional)</span></label>
        <textarea id="f_notes" maxlength="256" rows="3" placeholder="Previous athletic experience..."></textarea>
        <div style="text-align:right;font-size:10px;color:var(--text-muted);margin-top:3px;"><span id="f_notes_count">0</span>/256</div>
      </div>
      <div class="form-error hidden" id="athleteFormError"></div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeAthleteForm()">Cancel</button>
        <button class="btn-orange" id="athleteFormSaveBtn"><i class="fa-solid fa-check"></i> Save Athlete</button>
      </div>
    </div>
  </div>
</div>

<!-- IMPORT MODAL -->
<div class="overlay hidden" id="importOverlay">
  <div class="modal">
    <div class="modal-hd">
      <div><div class="modal-title">Import CSV</div><div class="modal-sub">Bulk add athletes</div></div>
      <button class="modal-x" onclick="closeOverlay('importOverlay')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <div class="template-bar">
        <i class="fa-solid fa-file-csv"></i>
        <div><div class="template-label">Need the format?</div><button class="btn-link" id="downloadTemplateBtn">Download CSV template</button></div>
      </div>
      <div class="upload-area" id="uploadArea">
        <i class="fa-solid fa-cloud-arrow-up"></i>
        <p>Drag & drop or <label class="btn-link" style="cursor:pointer;">browse<input type="file" id="csvFileInput" accept=".csv" style="display:none;" /></label></p>
      </div>
      <div class="hidden" id="importPreview">
        <div class="preview-hd"><span id="previewCount"></span><button class="btn-link" onclick="clearImport()">Clear</button></div>
        <div class="preview-scroll"><table class="preview-tbl" id="previewTable"></table></div>
      </div>
      <div class="form-error hidden" id="importError"></div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeOverlay('importOverlay')">Cancel</button>
        <button class="btn-orange hidden" id="importSaveBtn"><i class="fa-solid fa-file-arrow-up"></i> Import</button>
      </div>
    </div>
  </div>
</div>

<!-- DOSSIER WIZARD MODAL -->
<div class="overlay hidden" id="dossierOverlay" onclick="overlayBgClick(event)">
  <div class="dossier-modal" id="dossierModal">
    <div id="dossierContent"></div>
  </div>
</div>

<script type="module">
import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';
(async () => {

const supabase = createClient(
  'https://kbewlrudpdqmvdsbljen.supabase.co',
  'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtiZXdscnVkcGRxbXZkc2JsamVuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2ODkxNDQsImV4cCI6MjA4OTI2NTE0NH0.RYeII_T640_x4AVrThyYgy3nJcHfHc6iUVkWy2R9GgI'
);

// ── Constants ─────────────────────────────────────────────────────────────────
const EV_COLOR = { Sprints:'ev-sprints', Distance:'ev-distance', Throws:'ev-throws' };
const attState = {};
const PAPERWORK_FIELDS = [
  { key:'physical_exam',       label:'Physical Exam' },
  { key:'activities_contract', label:'Activities Contract' },
  { key:'concussion_form',     label:'Concussion Form' },
  { key:'heat_illness_form',   label:'Heat Illness Form' },
  { key:'cardiac_arrest_form', label:'Cardiac Arrest Form' },
  { key:'emergency_card',      label:'Emergency Card' },
  { key:'team_contract',       label:'Team Contract' },
];

// ── Auth ──────────────────────────────────────────────────────────────────────
const { data: { session } } = await supabase.auth.getSession();
if (!session) { window.location.href = '/dashboard'; return; }
const { data: profile } = await supabase.from('profiles').select('*').eq('id', session.user.id).single();
const email = session.user.email;
document.getElementById('userEmail').textContent = email;
document.getElementById('userAv').textContent = email.slice(0,2).toUpperCase();

if (profile?.role === 'manager') {
  document.getElementById('rosterBody').innerHTML = '<div class="loading-cell"><i class="fa-solid fa-lock"></i> Managers cannot view the full roster.</div>';
  document.getElementById('rosterCount').textContent = '';
  ['exportBtn','addAthleteBtn','importBtn'].forEach(id => document.getElementById(id).style.display = 'none');
  return;
}

// ── Drawer ─────────────────────────────────────────────────────────────────────
window.openDrawer  = () => { document.getElementById('sidebar').classList.add('open'); document.getElementById('drawerOverlay').classList.add('visible'); document.body.style.overflow='hidden'; };
window.closeDrawer = () => { document.getElementById('sidebar').classList.remove('open'); document.getElementById('drawerOverlay').classList.remove('visible'); document.body.style.overflow=''; };
document.getElementById('signoutBtn').addEventListener('click', async () => { await supabase.auth.signOut(); window.location.href = '/dashboard'; });

// ── Load ───────────────────────────────────────────────────────────────────────
let allAthletes = [];
let activeFilter = 'all';

async function loadRoster() {
  const { data, error } = await supabase.from('athlete_summary').select('*').order('last_name');
  if (error) { document.getElementById('rosterBody').innerHTML = `<div class="loading-cell">Error: ${error.message}</div>`; return; }
  allAthletes = data || [];
  applyFilters();
}
await loadRoster();

// ── Filters ────────────────────────────────────────────────────────────────────
window.setFilter = (btn, filter) => {
  document.querySelectorAll('.fpill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  activeFilter = filter;
  applyFilters();
};
document.getElementById('searchInput').addEventListener('input', applyFilters);

function applyFilters() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const filtered = allAthletes.filter(a => {
    if (activeFilter !== 'all') {
      const [type, val] = activeFilter.split(':');
      if (type === 'team'      && a.team !== val)                    return false;
      if (type === 'status'    && a.status !== val)                  return false;
      if (type === 'season'    && !(a.season||[]).includes(val))     return false;
      if (type === 'paperwork' && a.paperwork_status !== val)        return false;
    }
    if (search) {
      const name = `${a.first_name} ${a.last_name}`.toLowerCase();
      if (!name.includes(search) && !(a.email||'').toLowerCase().includes(search)) return false;
    }
    return true;
  });
  renderTable(filtered);
}

// ── Badges ─────────────────────────────────────────────────────────────────────
function paperworkBadge(status) {
  if (status === 'No Physical')        return '<span class="badge badge-danger">No Physical</span>';
  if (status === 'Missing Docs')       return '<span class="badge badge-warn">Missing Docs</span>';
  if (status === 'Paperwork Complete') return '<span class="badge badge-ok">Complete</span>';
  return '<span class="badge badge-neutral">—</span>';
}
function statusBadge(status) {
  const map = { Active:'badge-active', Suspended:'badge-warn', Ineligible:'badge-danger', Quit:'badge-neutral', Cut:'badge-neutral' };
  return `<span class="badge ${map[status]||'badge-neutral'}">${status||'Active'}</span>`;
}

// ── Attendance ─────────────────────────────────────────────────────────────────
function attClass(s) {
  return { Present:'att-present', Late:'att-late', Excused:'att-excused', Unexcused:'att-unexcused' }[s] || '';
}
function attButtons(id, current) {
  return ['P','L','E','U'].map((lbl, i) => {
    const s = ['Present','Late','Excused','Unexcused'][i];
    const cls = current === s ? attClass(s) + ' att-active' : '';
    return `<button class="att-btn ${cls}" onclick="event.stopPropagation();markAttendance('${id}','${s}')">${lbl}</button>`;
  }).join('');
}
async function markAttendance(athleteId, status) {
  const prev = attState[athleteId];
  const next  = prev === status ? null : status;
  attState[athleteId] = next;
  const attEl = document.getElementById(`att-${athleteId}`);
  if (attEl) attEl.innerHTML = attButtons(athleteId, next);
  const today = new Date().toISOString().split('T')[0];
  if (next) {
    await supabase.from('attendance').upsert([{ practice_date: today, athlete_id: athleteId, status: next }], { onConflict: 'practice_date,athlete_id' });
  } else {
    await supabase.from('attendance').delete().eq('practice_date', today).eq('athlete_id', athleteId);
  }
}

// ── Render flight sheet ────────────────────────────────────────────────────────
function renderTable(athletes) {
  const list = document.getElementById('rosterBody');
  document.getElementById('rosterCount').textContent = `${athletes.length} athlete${athletes.length !== 1 ? 's' : ''}`;
  if (!athletes.length) { list.innerHTML = '<div class="loading-cell">No athletes match.</div>'; return; }
  list.innerHTML = athletes.map(a => {
    const dim = ['Quit','Cut'].includes(a.status) ? 'row-dim' : '';
    const cur = attState[a.id] || null;
    const ev  = a.event_group;
    return `<div class="flight-row ${dim}" onclick="openDossier('${a.id}')">
      <div class="av ${EV_COLOR[ev]||'ev-default'}">${a.first_name[0]}${a.last_name[0]}</div>
      <div class="row-name">${a.first_name} ${a.last_name}</div>
      <div class="row-badges">
        ${statusBadge(a.status||'Active')}
        ${ev ? `<span class="badge ${EV_COLOR[ev]}-badge">${ev}</span>` : ''}
        ${paperworkBadge(a.paperwork_status)}
      </div>
      <div class="row-att" id="att-${a.id}" onclick="event.stopPropagation()">${attButtons(a.id, cur)}</div>
      <button class="row-edit-btn" onclick="event.stopPropagation();openDossier('${a.id}')"><i class="fa-solid fa-pen-to-square"></i></button>
    </div>`;
  }).join('');
}

// ── DOSSIER WIZARD ─────────────────────────────────────────────────────────────
let currentAthleteId = null;
let dossierPhase = 1;
const DOSSIER_TOTAL = 8;
const DOSSIER_PHASES = ['Info','Athlete','School','Athletics','Family','Status','Paperwork','Notes'];

window.overlayBgClick = (e) => { if (e.target === document.getElementById('dossierOverlay')) closeDossier(); };
window.closeDossier = () => { document.getElementById('dossierOverlay').classList.add('hidden'); document.body.style.overflow = ''; };

window.openDossier = async (id) => {
  currentAthleteId = id;
  const a = allAthletes.find(x => x.id === id);
  if (!a) return;
  dossierPhase = 1;
  renderDossier(a);
  document.getElementById('dossierOverlay').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
};

function dossierProgress() {
  return `<div class="d-tab-bar">
    ${DOSSIER_PHASES.map((p,i) => `<button class="d-tab ${i+1 === dossierPhase ? 'active' : ''}" onclick="goToPhase(${i+1})">${p}</button>`).join('')}
  </div>`;
}

function dossierHeader(a) {
  return `<div class="d-header">
    <div class="d-header-top">
      <div>
        <div class="d-brand-badge">JRTXCTF // TIGER NET</div>
        <div class="d-athlete-name">${a.first_name} ${a.last_name}</div>
      </div>
      <div class="d-header-actions">
        <button class="d-save-btn" id="dossierSaveBtn" onclick="saveDossier()"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        <button class="d-close-btn" onclick="closeDossier()"><i class="fa-solid fa-xmark"></i></button>
      </div>
    </div>
    ${dossierProgress()}
  </div>`;
}

function renderDossier(a) {
  document.getElementById('dossierContent').innerHTML = dossierHeader(a) + `<div class="d-body" id="dossierBody">${buildPhase(a, dossierPhase)}</div>`;
}

function buildPhase(a, phase) {
  const seasons = a.season || [];
  const activities = a.activities || [];
  const sprint_addons = a.sprint_addons || [];

  if (phase === 1) return `
    <div class="d-phase">
      <h2 class="d-step-title">Athlete Overview</h2>
      <p class="d-step-desc">Review and confirm this athlete's current information.</p>
      <div class="d-info-grid">
        <div class="d-info-row"><span>Name</span><span>${a.first_name} ${a.last_name}</span></div>
        <div class="d-info-row"><span>Grade</span><span>${a.grade}</span></div>
        <div class="d-info-row"><span>Team</span><span>${a.team}</span></div>
        <div class="d-info-row"><span>Event Group</span><span>${a.event_group || '—'}</span></div>
        <div class="d-info-row"><span>Status</span><span>${statusBadge(a.status||'Active')}</span></div>
        <div class="d-info-row"><span>Paperwork</span><span>${paperworkBadge(a.paperwork_status)}</span></div>
        <div class="d-info-row"><span>Season(s)</span><span>${seasons.join(', ') || '—'}</span></div>
        <div class="d-info-row"><span>Email</span><span>${a.email}</span></div>
        <div class="d-info-row"><span>Phone</span><span>${a.phone}</span></div>
      </div>
      <div class="d-action-row right"><button class="d-btn-primary" onclick="dossierNext()">Edit Information &rarr;</button></div>
    </div>`;

  if (phase === 2) return `
    <div class="d-phase">
      <h2 class="d-step-title">Athlete Details</h2>
      <p class="d-step-desc">Basic information and contact details.</p>
      <div class="d-input-grid">
        <div class="d-input-group"><label>First Name</label><input type="text" id="d_fn" value="${a.first_name}" /></div>
        <div class="d-input-group"><label>Last Name</label><input type="text" id="d_ln" value="${a.last_name}" /></div>
      </div>
      <div class="d-input-grid">
        <div class="d-input-group"><label>Grade</label><select id="d_gr">${[9,10,11,12].map(g=>`<option value="${g}" ${a.grade==g?'selected':''}>${g}th Grade</option>`).join('')}</select></div>
        <div class="d-input-group"><label>Birthday</label><input type="date" id="d_bday" value="${a.birthday||''}" /></div>
      </div>
      <div class="d-input-grid">
        <div class="d-input-group"><label>Phone</label><input type="tel" id="d_ph" value="${a.phone||''}" placeholder="(555) 555-5555" /></div>
        <div class="d-input-group"><label>Email</label><input type="email" id="d_em" value="${a.email||''}" placeholder="athlete@example.com" /></div>
      </div>
      <div class="d-input-grid">
        <div class="d-input-group"><label>Team</label><select id="d_tm"><option value="Boys" ${a.team==='Boys'?'selected':''}>Boys</option><option value="Girls" ${a.team==='Girls'?'selected':''}>Girls</option></select></div>
        <div class="d-input-group"><label>Athlete Type</label><select id="d_type"><option value="New Athlete" ${a.athlete_type==='New Athlete'?'selected':''}>New Athlete</option><option value="Returning Athlete" ${a.athlete_type==='Returning Athlete'?'selected':''}>Returning Athlete</option></select></div>
      </div>
      <div class="d-action-row space-between"><button class="d-btn-secondary" onclick="dossierPrev()">&larr; Back</button><button class="d-btn-primary" onclick="dossierNext()">Next: School &rarr;</button></div>
    </div>`;

  if (phase === 3) {
    const ms = a.middle_school || '';
    const isOther = ms === 'Other';
    const isSpec = a.is_specialty;
    const MIDDLE_SCHOOLS = ['Brookland Middle','Elko Middle','Fairfield Middle','George H. Moody Middle','Holman Middle','Hungary Creek Middle','L. Douglas Wilder Middle','Pocohontas Middle','Quioccasin Middle','John Rolfe Middle','Short Pump Middle','Tuckahoe Middle','Other'];
    return `<div class="d-phase">
      <h2 class="d-step-title">Academic Background</h2>
      <p class="d-step-desc">School information and specialty programs.</p>
      <div class="d-input-group">
        <label>Middle School Attended</label>
        <select id="d_ms" onchange="document.getElementById('d_ms_other_wrap').classList.toggle('hidden', this.value !== 'Other')">
          <option value="">Select...</option>
          ${MIDDLE_SCHOOLS.map(s=>`<option value="${s}" ${ms===s?'selected':''}>${s}</option>`).join('')}
        </select>
      </div>
      <div class="d-input-group ${isOther ? '' : 'hidden'}" id="d_ms_other_wrap">
        <label>Please specify</label><input type="text" id="d_ms_other" value="${a.other_middle_school||''}" placeholder="School name" />
      </div>
      <div class="d-highlight-panel">
        <label class="d-long-label">Are you a student in a specialty center?</label>
        <div class="d-radio-group">
          <label class="d-radio-label"><input type="radio" name="d_spec" value="yes" ${isSpec?'checked':''} onchange="document.getElementById('d_spec_prog_wrap').classList.toggle('hidden', this.value!=='yes')" /> <span>Yes</span></label>
          <label class="d-radio-label"><input type="radio" name="d_spec" value="no" ${!isSpec?'checked':''} onchange="document.getElementById('d_spec_prog_wrap').classList.add('hidden')" /> <span>No</span></label>
        </div>
      </div>
      <div class="d-input-group ${isSpec ? '' : 'hidden'}" id="d_spec_prog_wrap">
        <label>Program</label>
        <select id="d_spec_prog">
          <option value="">Select...</option>
          ${['Advance College Academy','International Baccalaureate','Spanish Language Immersion'].map(p=>`<option value="${p}" ${a.specialty_program===p?'selected':''}>${p}</option>`).join('')}
        </select>
      </div>
      <div class="d-action-row space-between"><button class="d-btn-secondary" onclick="dossierPrev()">&larr; Back</button><button class="d-btn-primary" onclick="dossierNext()">Next: Athletics &rarr;</button></div>
    </div>`;
  }

  if (phase === 4) {
    const ACTS = ['Basketball','Competition Cheer','Dance Team','Debate','Field Hockey','Football','Forensics','Golf','Gymnastics','JROTC','Marching Band','Sideline Cheer','Step Team','Swim','Volleyball','Wrestling'];
    const hasAct = a.has_activities;
    return `<div class="d-phase">
      <h2 class="d-step-title">Athletic Profile</h2>
      <p class="d-step-desc">Team and prior activity this academic year.</p>
      <div class="d-highlight-panel">
        <label class="d-long-label">Has this athlete participated in other sports or activities this year?</label>
        <div class="d-radio-group">
          <label class="d-radio-label"><input type="radio" name="d_hact" value="yes" ${hasAct?'checked':''} onchange="document.getElementById('d_acts_wrap').classList.toggle('hidden',false)" /> <span>Yes</span></label>
          <label class="d-radio-label"><input type="radio" name="d_hact" value="no" ${!hasAct?'checked':''} onchange="document.getElementById('d_acts_wrap').classList.add('hidden')" /> <span>No</span></label>
        </div>
      </div>
      <div class="d-input-group ${hasAct ? '' : 'hidden'}" id="d_acts_wrap">
        <label>Select all that apply</label>
        <div class="d-checkbox-grid">${ACTS.map(act=>`<label class="d-checkbox-label"><input type="checkbox" name="d_act" value="${act}" ${activities.includes(act)?'checked':''} /> <span>${act}</span></label>`).join('')}</div>
      </div>
      <div class="d-action-row space-between"><button class="d-btn-secondary" onclick="dossierPrev()">&larr; Back</button><button class="d-btn-primary" onclick="dossierNext()">Next: Family &rarr;</button></div>
    </div>`;
  }

  if (phase === 5) {
    const hasP2 = !!a.parent2_name;
    return `<div class="d-phase">
      <h2 class="d-step-title">Parent / Guardian</h2>
      <p class="d-step-desc">Emergency contact information.</p>
      <div class="d-input-group"><label>Parent / Guardian 1 Full Name</label><input type="text" id="d_p1n" value="${a.parent1_name||''}" /></div>
      <div class="d-input-grid">
        <div class="d-input-group"><label>Phone</label><input type="tel" id="d_p1p" value="${a.parent1_phone||''}" placeholder="(555) 555-5555" /></div>
        <div class="d-input-group"><label>Email</label><input type="email" id="d_p1e" value="${a.parent1_email||''}" placeholder="parent@example.com" /></div>
      </div>
      <div class="d-toggle-container">
        <label class="d-toggle-label"><input type="checkbox" id="d_add_p2" ${hasP2?'checked':''} onchange="document.getElementById('d_p2_wrap').classList.toggle('hidden', !this.checked)" /><span class="d-toggle-text">+ Add secondary contact</span></label>
      </div>
      <div class="d-highlight-panel ${hasP2 ? '' : 'hidden'}" id="d_p2_wrap">
        <div class="d-input-group"><label>Parent / Guardian 2 Full Name</label><input type="text" id="d_p2n" value="${a.parent2_name||''}" /></div>
        <div class="d-input-grid">
          <div class="d-input-group"><label>Phone</label><input type="tel" id="d_p2p" value="${a.parent2_phone||''}" placeholder="(555) 555-5555" /></div>
          <div class="d-input-group"><label>Email</label><input type="email" id="d_p2e" value="${a.parent2_email||''}" placeholder="parent2@example.com" /></div>
        </div>
      </div>
      <div class="d-action-row space-between"><button class="d-btn-secondary" onclick="dossierPrev()">&larr; Back</button><button class="d-btn-primary" onclick="dossierNext()">Next: Status &rarr;</button></div>
    </div>`;
  }

  if (phase === 6) {
    const STATUS_OPTIONS = ['Active','Suspended','Ineligible','Quit','Cut'];
    const curStatus = a.status || 'Active';
    return `<div class="d-phase">
      <h2 class="d-step-title">Athlete Status</h2>
      <p class="d-step-desc">Set this athlete's current program status.</p>
      <div class="d-status-grid">
        ${STATUS_OPTIONS.map(s => {
          const icons = { Active:'fa-circle-check', Suspended:'fa-circle-pause', Ineligible:'fa-circle-xmark', Quit:'fa-circle-minus', Cut:'fa-scissors' };
          const colors = { Active:'status-active', Suspended:'status-warn', Ineligible:'status-danger', Quit:'status-neutral', Cut:'status-neutral' };
          return `<label class="d-status-card">
            <input type="radio" name="d_status" value="${s}" ${curStatus===s?'checked':''} class="d-hidden-radio" />
            <div class="d-card-content">
              <i class="fa-solid ${icons[s]} d-status-icon ${colors[s]}"></i>
              <span class="d-status-label">${s}</span>
            </div>
          </label>`;
        }).join('')}
      </div>
      <div class="d-input-group" style="margin-top:1.5rem;"><label>Status Notes (optional)</label><input type="text" id="d_status_notes" value="${a.status_notes||''}" placeholder="Reason for status change..." /></div>
      <div class="d-action-row space-between"><button class="d-btn-secondary" onclick="dossierPrev()">&larr; Back</button><button class="d-btn-primary" onclick="dossierNext()">Next: Paperwork &rarr;</button></div>
    </div>`;
  }

  if (phase === 7) {
    return `<div class="d-phase">
      <h2 class="d-step-title">Paperwork Checklist</h2>
      <p class="d-step-desc">Mark off documents that have been received.</p>
      <div class="d-paperwork-list">
        ${PAPERWORK_FIELDS.map(f => {
          const checked = a[f.key];
          return `<label class="d-pw-item ${checked ? 'pw-complete' : 'pw-missing'}">
            <input type="checkbox" name="d_pw" data-key="${f.key}" ${checked?'checked':''} onchange="this.closest('.d-pw-item').classList.toggle('pw-complete',this.checked);this.closest('.d-pw-item').classList.toggle('pw-missing',!this.checked)" />
            <div class="d-pw-info">
              <span class="d-pw-label">${f.label}</span>
              <span class="d-pw-status">${checked ? '<i class="fa-solid fa-check"></i> Received' : '<i class="fa-solid fa-xmark"></i> Missing'}</span>
            </div>
          </label>`;
        }).join('')}
      </div>
      <div class="d-action-row space-between"><button class="d-btn-secondary" onclick="dossierPrev()">&larr; Back</button><button class="d-btn-primary" onclick="dossierNext()">Next: Notes &rarr;</button></div>
    </div>`;
  }

  if (phase === 8) {
    return `<div class="d-phase">
      <h2 class="d-step-title">Additional Notes</h2>
      <p class="d-step-desc">Any additional information about this athlete.</p>
      <div class="d-input-group">
        <label>Notes <span style="font-weight:400;color:var(--text-muted)">(optional, max 256 chars)</span></label>
        <textarea id="d_notes" maxlength="256" rows="5" placeholder="Previous athletic experience, injuries, anything else...">${a.notes||''}</textarea>
        <div class="d-char-counter"><span id="d_notes_count">${(a.notes||'').length}</span> / 256</div>
      </div>
      <div class="d-form-error hidden" id="dossierError"></div>
      <div class="d-action-row right">
        <button class="d-btn-secondary" onclick="dossierPrev()">&larr; Back</button>
      </div>
    </div>`;
  }
  return '';
}

window.goToPhase = (phase) => {
  dossierPhase = phase;
  const a = allAthletes.find(x => x.id === currentAthleteId);
  document.getElementById('dossierBody').innerHTML = buildPhase(a, dossierPhase);
  document.querySelectorAll('.d-tab').forEach((t,i) => t.classList.toggle('active', i+1 === dossierPhase));
  document.getElementById('dossierModal').scrollTop = 0;
  if (dossierPhase === 8) {
    const ta = document.getElementById('d_notes');
    if (ta) ta.addEventListener('input', () => { document.getElementById('d_notes_count').textContent = ta.value.length; });
  }
};
window.dossierNext = () => { if (dossierPhase < DOSSIER_TOTAL) goToPhase(dossierPhase + 1); };
window.dossierPrev = () => { if (dossierPhase > 1) goToPhase(dossierPhase - 1); };

window.saveDossier = async function saveDossier() {
  const btn = document.getElementById('dossierSaveBtn'); if (!btn) return;
  const errEl = document.getElementById('dossierError');
  if (errEl) errEl.classList.add('hidden');
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

  // Collect all data from all phases (read from DOM where available)
  const get = id => { const el = document.getElementById(id); return el ? el.value.trim() : null; };
  const getAll = name => [...document.querySelectorAll(`input[name="${name}"]:checked`)].map(i => i.value);

  const regUpdate = {
    first_name:    get('d_fn'),    last_name: get('d_ln'),
    grade:         parseInt(get('d_gr')||'0')||null,
    birthday:      get('d_bday')  || null,
    phone:         get('d_ph'),    email:     get('d_em'),
    team:          get('d_tm'),    athlete_type: get('d_type'),
    middle_school: get('d_ms'),    other_middle_school: get('d_ms_other') || null,
    is_specialty:  document.querySelector('input[name="d_spec"]:checked')?.value === 'yes',
    specialty_program: get('d_spec_prog') || null,
    has_activities: document.querySelector('input[name="d_hact"]:checked')?.value === 'yes',
    activities:    getAll('d_act'),
    parent1_name:  get('d_p1n'),   parent1_phone: get('d_p1p'), parent1_email: get('d_p1e'),
    parent2_name:  get('d_p2n')  || null, parent2_phone: get('d_p2p') || null, parent2_email: get('d_p2e') || null,
    notes:         get('d_notes') || null,
  };

  // Remove null keys to avoid overwriting with null
  Object.keys(regUpdate).forEach(k => { if (regUpdate[k] === null || regUpdate[k] === '') delete regUpdate[k]; });

  const { error: regErr } = await supabase.from('registrations').update(regUpdate).eq('id', currentAthleteId);
  if (regErr) {
    if (errEl) { errEl.textContent = regErr.message; errEl.classList.remove('hidden'); }
    btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
    return;
  }

  // Update athlete_records
  const pwUpdate = {};
  PAPERWORK_FIELDS.forEach(f => {
    const cb = document.querySelector(`input[name="d_pw"][data-key="${f.key}"]`);
    if (cb) pwUpdate[f.key] = cb.checked;
  });
  const statusEl = document.querySelector('input[name="d_status"]:checked');
  if (statusEl) { pwUpdate.status = statusEl.value; pwUpdate.status_changed_by = session.user.id; }
  const statusNotes = get('d_status_notes');
  if (statusNotes !== null) pwUpdate.status_notes = statusNotes;

  if (Object.keys(pwUpdate).length) {
    await supabase.from('athlete_records').update(pwUpdate).eq('athlete_id', currentAthleteId);
  }

  await loadRoster();
  const b = document.getElementById('dossierSaveBtn');
  if (b) { b.disabled = false; b.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save'; }
  closeDossier();
}

// ── Unified add form ───────────────────────────────────────────────────────────
let formMode = 'add';
window.closeOverlay = (id) => { document.getElementById(id).classList.add('hidden'); document.body.style.overflow = ''; };
window.closeAthleteForm = () => closeOverlay('athleteFormOverlay');
window.toggleP2 = () => { document.getElementById('f_p2_wrap').classList.toggle('hidden', !document.getElementById('f_add_p2').checked); };

document.getElementById('f_ms').addEventListener('change', e => { document.getElementById('f_ms_other_wrap').classList.toggle('hidden', e.target.value !== 'Other'); });
document.getElementById('f_spec').addEventListener('change', e => { document.getElementById('f_spec_prog_wrap').classList.toggle('hidden', e.target.value !== 'yes'); });
document.getElementById('f_hact').addEventListener('change', e => { document.getElementById('f_activities_wrap').classList.toggle('hidden', e.target.value !== 'yes'); });
document.getElementById('f_notes').addEventListener('input', e => { document.getElementById('f_notes_count').textContent = e.target.value.length; });

function openAthleteForm(mode, athlete) {
  formMode = mode;
  document.getElementById('formModalTitle').textContent = mode === 'add' ? 'Add Athlete' : 'Edit Athlete';
  document.getElementById('formModalSub').textContent   = mode === 'add' ? 'Manually add to roster' : 'Update athlete information';
  document.getElementById('athleteFormSaveBtn').innerHTML = mode === 'add' ? '<i class="fa-solid fa-check"></i> Save Athlete' : '<i class="fa-solid fa-floppy-disk"></i> Save Changes';

  // Reset
  document.getElementById('athleteFormOverlay').querySelectorAll('input[type=text],input[type=email],input[type=tel],input[type=date],select,textarea').forEach(el => el.value = '');
  document.querySelectorAll('input[name=f_s],input[name=f_sa],input[name=f_act]').forEach(c => c.checked = false);
  document.getElementById('f_add_p2').checked = false;
  ['f_p2_wrap','f_ms_other_wrap','f_spec_prog_wrap','f_activities_wrap'].forEach(id => document.getElementById(id).classList.add('hidden'));
  document.getElementById('f_notes_count').textContent = '0';
  document.getElementById('athleteFormError').classList.add('hidden');

  if (mode === 'edit' && athlete) {
    const set = (id, val) => { const el = document.getElementById(id); if (el && val !== null && val !== undefined) el.value = val; };
    set('f_fn', athlete.first_name); set('f_ln', athlete.last_name);
    set('f_gr', String(athlete.grade||'')); set('f_bday', athlete.birthday||'');
    set('f_em', athlete.email); set('f_ph', athlete.phone);
    set('f_tm', athlete.team); set('f_type', athlete.athlete_type||'New Athlete');
    set('f_ev', athlete.event_group||''); set('f_ms', athlete.middle_school||'');
    set('f_spec', athlete.is_specialty ? 'yes' : 'no');
    set('f_hact', athlete.has_activities ? 'yes' : 'no');
    set('f_notes', athlete.notes||'');
    document.getElementById('f_notes_count').textContent = (athlete.notes||'').length;
    set('f_p1n', athlete.parent1_name); set('f_p1p', athlete.parent1_phone); set('f_p1e', athlete.parent1_email);
    if (athlete.parent2_name) {
      document.getElementById('f_add_p2').checked = true;
      document.getElementById('f_p2_wrap').classList.remove('hidden');
      set('f_p2n', athlete.parent2_name); set('f_p2p', athlete.parent2_phone); set('f_p2e', athlete.parent2_email);
    }
    (athlete.season||[]).forEach(s => { const cb = document.querySelector(`input[name=f_s][value="${s}"]`); if (cb) cb.checked = true; });
    (athlete.sprint_addons||[]).forEach(s => { const cb = document.querySelector(`input[name=f_sa][value="${s}"]`); if (cb) cb.checked = true; });
    (athlete.activities||[]).forEach(v => { const cb = document.querySelector(`input[name=f_act][value="${v}"]`); if (cb) cb.checked = true; });
    if (athlete.middle_school === 'Other') { document.getElementById('f_ms_other_wrap').classList.remove('hidden'); set('f_ms_other', athlete.other_middle_school); }
    if (athlete.is_specialty) { document.getElementById('f_spec_prog_wrap').classList.remove('hidden'); set('f_spec_prog', athlete.specialty_program); }
    if (athlete.has_activities) document.getElementById('f_activities_wrap').classList.remove('hidden');
  }
  document.getElementById('athleteFormOverlay').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}

document.getElementById('addAthleteBtn').addEventListener('click', () => openAthleteForm('add'));

document.getElementById('athleteFormSaveBtn').addEventListener('click', async () => {
  const btn = document.getElementById('athleteFormSaveBtn');
  const errEl = document.getElementById('athleteFormError');
  errEl.classList.add('hidden');
  const fn=document.getElementById('f_fn').value.trim(), ln=document.getElementById('f_ln').value.trim();
  const gr=parseInt(document.getElementById('f_gr').value), tm=document.getElementById('f_tm').value;
  const em=document.getElementById('f_em').value.trim(), ph=document.getElementById('f_ph').value.trim();
  const p1n=document.getElementById('f_p1n').value.trim(), p1p=document.getElementById('f_p1p').value.trim(), p1e=document.getElementById('f_p1e').value.trim();
  const ev=document.getElementById('f_ev').value||null, ms=document.getElementById('f_ms').value;
  const mso=document.getElementById('f_ms_other').value.trim();
  const spec=document.getElementById('f_spec').value==='yes', sp=document.getElementById('f_spec_prog').value||null;
  const hact=document.getElementById('f_hact').value==='yes';
  const acts=[...document.querySelectorAll('input[name=f_act]:checked')].map(i=>i.value);
  const sa=[...document.querySelectorAll('input[name=f_sa]:checked')].map(i=>i.value);
  const s=[...document.querySelectorAll('input[name=f_s]:checked')].map(i=>i.value);
  const bday=document.getElementById('f_bday').value||null, type=document.getElementById('f_type').value;
  const notes=document.getElementById('f_notes').value.trim()||null;
  const p2n=document.getElementById('f_p2n').value.trim()||null, p2p=document.getElementById('f_p2p').value.trim()||null, p2e=document.getElementById('f_p2e').value.trim()||null;
  if (!fn||!ln||!gr||!tm||!em||!ph||!p1n||!p1p||!p1e||!ms) { errEl.textContent='Please fill in all required fields.'; errEl.classList.remove('hidden'); return; }
  if (!s.length) { errEl.textContent='Select at least one season.'; errEl.classList.remove('hidden'); return; }
  if (ms==='Other'&&!mso) { errEl.textContent='Please specify the middle school.'; errEl.classList.remove('hidden'); return; }
  btn.disabled=true; btn.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
  const record = { athlete_type:type, first_name:fn, last_name:ln, grade:gr, team:tm, email:em, phone:ph, season:s, event_group:ev, sprint_addons:sa, birthday:bday, middle_school:ms, other_middle_school:mso||null, is_specialty:spec, specialty_program:sp, has_activities:hact, activities:acts, parent1_name:p1n, parent1_phone:p1p, parent1_email:p1e, parent2_name:p2n, parent2_phone:p2p, parent2_email:p2e, notes };
  let error;
  if (formMode==='add') ({ error } = await supabase.from('registrations').insert([record]));
  else ({ error } = await supabase.from('registrations').update(record).eq('id', currentAthleteId));
  if (error) { errEl.textContent=error.message; errEl.classList.remove('hidden'); btn.disabled=false; btn.innerHTML=formMode==='add'?'<i class="fa-solid fa-check"></i> Save Athlete':'<i class="fa-solid fa-floppy-disk"></i> Save Changes'; return; }
  await loadRoster();
  closeAthleteForm();
  btn.disabled=false; btn.innerHTML=formMode==='add'?'<i class="fa-solid fa-check"></i> Save Athlete':'<i class="fa-solid fa-floppy-disk"></i> Save Changes';
});

// ── Export CSV ─────────────────────────────────────────────────────────────────
document.getElementById('exportBtn').addEventListener('click', () => {
  const headers = ['Last Name','First Name','Grade','Birthday','Team','Season','Event','Status','Paperwork','Email','Phone','Parent','Parent Phone','Parent Email'];
  const rows = allAthletes.map(a => [a.last_name,a.first_name,a.grade,a.birthday||'',a.team,(a.season||[]).join('; '),a.event_group||'',a.status||'',a.paperwork_status||'',a.email,a.phone,a.parent1_name,a.parent1_phone,a.parent1_email]);
  const csv = [headers,...rows].map(r=>r.map(v=>`"${String(v||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const url = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  const a = document.createElement('a'); a.href=url; a.download=`jrtxctf-roster-${new Date().toISOString().split('T')[0]}.csv`; a.click();
  URL.revokeObjectURL(url);
});

// ── Import CSV ─────────────────────────────────────────────────────────────────
document.getElementById('importBtn').addEventListener('click', () => { document.getElementById('importOverlay').classList.remove('hidden'); document.body.style.overflow='hidden'; });
document.getElementById('downloadTemplateBtn').addEventListener('click', () => {
  const headers = ['first_name','last_name','grade','team','season (semicolon separated)','event_group','email','phone','parent1_name','parent1_phone','parent1_email'];
  const example = ['Jane','Smith','10','Girls','Cross Country; Outdoor Track & Field','Distance','jane@example.com','(555) 555-5555','Bob Smith','(555) 555-5556','bob@example.com'];
  const csv = [headers,example].map(r=>r.map(v=>`"${v}"`).join(',')).join('\n');
  const url = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  const a = document.createElement('a'); a.href=url; a.download='jrtxctf-import-template.csv'; a.click();
  URL.revokeObjectURL(url);
});
const uploadArea = document.getElementById('uploadArea');
uploadArea.addEventListener('dragover', e=>{e.preventDefault();uploadArea.classList.add('drag-over');});
uploadArea.addEventListener('dragleave', ()=>uploadArea.classList.remove('drag-over'));
uploadArea.addEventListener('drop', e=>{e.preventDefault();uploadArea.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f)parseCSV(f);});
document.getElementById('csvFileInput').addEventListener('change', e=>{const f=e.target.files[0];if(f)parseCSV(f);});
let parsedAthletes = [];
function parseCSV(file) {
  const reader = new FileReader();
  reader.onload = e => {
    const lines = e.target.result.split('\n').filter(l=>l.trim());
    const headers = lines[0].split(',').map(h=>h.replace(/"/g,'').trim().toLowerCase());
    parsedAthletes = lines.slice(1).map(row => {
      const vals = row.match(/(".*?"|[^,]+)/g)||[];
      const clean = vals.map(v=>v.replace(/^"|"$/g,'').trim());
      const obj = {}; headers.forEach((h,i)=>{obj[h]=clean[i]||'';});
      const seasonRaw = obj['season (semicolon separated)']||obj['season']||'';
      return { athlete_type:'New Athlete', first_name:obj.first_name, last_name:obj.last_name, grade:parseInt(obj.grade)||null, team:obj.team, season:seasonRaw.split(';').map(s=>s.trim()).filter(Boolean), event_group:obj.event_group||null, email:obj.email, phone:obj.phone, parent1_name:obj.parent1_name, parent1_phone:obj.parent1_phone, parent1_email:obj.parent1_email, middle_school:'Other', is_specialty:false, has_activities:false };
    }).filter(a=>a.first_name&&a.last_name);
    if (!parsedAthletes.length) { const e=document.getElementById('importError'); e.textContent='No valid rows found.'; e.classList.remove('hidden'); return; }
    document.getElementById('previewCount').textContent = `${parsedAthletes.length} athlete${parsedAthletes.length!==1?'s':''} ready`;
    document.getElementById('previewTable').innerHTML = `<thead><tr>${['Name','Grade','Team','Season(s)','Event','Email'].map(h=>`<th>${h}</th>`).join('')}</tr></thead><tbody>${parsedAthletes.map(a=>`<tr><td>${a.first_name} ${a.last_name}</td><td>${a.grade||'—'}</td><td>${a.team||'—'}</td><td>${(a.season||[]).join(', ')||'—'}</td><td>${a.event_group||'—'}</td><td>${a.email||'—'}</td></tr>`).join('')}</tbody>`;
    document.getElementById('importPreview').classList.remove('hidden');
    document.getElementById('importSaveBtn').classList.remove('hidden');
    uploadArea.classList.add('hidden');
  };
  reader.readAsText(file);
}
window.clearImport = () => { parsedAthletes=[]; document.getElementById('importPreview').classList.add('hidden'); document.getElementById('importSaveBtn').classList.add('hidden'); uploadArea.classList.remove('hidden'); document.getElementById('csvFileInput').value=''; };
document.getElementById('importSaveBtn').addEventListener('click', async () => {
  const btn=document.getElementById('importSaveBtn');
  btn.disabled=true; btn.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i> Importing...';
  const { error } = await supabase.from('registrations').insert(parsedAthletes);
  if (error) { const e=document.getElementById('importError'); e.textContent='Import failed: '+error.message; e.classList.remove('hidden'); btn.disabled=false; btn.innerHTML='<i class="fa-solid fa-file-arrow-up"></i> Import'; return; }
  await loadRoster(); closeOverlay('importOverlay'); clearImport();
  btn.disabled=false; btn.innerHTML='<i class="fa-solid fa-file-arrow-up"></i> Import';
});

})(); // end IIFE
</script>
</body>
</html>

