  --c-throws-bg:   #FAECE7; --c-throws-txt:  #712B13;
  --c-default-bg:  #EEEDFE; --c-default-txt: #3C3489;

  --c-active-bg:   #E1F5EE; --c-active-txt:  #085041;
  --c-warn-bg:     #FAEEDA; --c-warn-txt:    #633806;
  --c-danger-bg:   #FCEBEB; --c-danger-txt:  #791F1F;
  --c-neutral-bg:  #F1EFE8; --c-neutral-txt: #5F5E5A;
  --c-boys-bg:     #E6F1FB; --c-boys-txt:    #0C447C;
  --c-girls-bg:    #FBEAF0; --c-girls-txt:   #72243E;
  --c-xc-bg:       #EAF3DE; --c-xc-txt:      #27500A;
  --c-indoor-bg:   #EEEDFE; --c-indoor-txt:  #3C3489;
  --c-outdoor-bg:  #E6F1FB; --c-outdoor-txt: #0C447C;
