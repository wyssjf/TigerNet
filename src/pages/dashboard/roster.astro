---
// src/pages/dashboard/roster.astro
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>JRTXCTF | Roster</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
</head>
<body>

<div class="mobile-topbar">
  <div class="mobile-brand"><i class="fa-solid fa-paw" style="color:#FF6700;font-size:16px;"></i> JRTXCTF</div>
  <button class="hamburger" onclick="openDrawer()"><i class="fa-solid fa-bars"></i></button>
</div>
<div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

<div class="layout">
  <aside class="sidebar" id="sidebar">
    <div class="sb-brand">
      <i class="fa-solid fa-paw" style="color:#FF6700;font-size:18px;"></i>
      <span class="sb-name">JRTXCTF</span>
    </div>
    <div class="sb-section">PROGRAM</div>
    <nav class="sb-nav">
      <a href="/dashboard/roster" class="nav-item active"><span class="nav-dot"></span> Roster</a>
      <a href="/dashboard/attendance" class="nav-item"><span class="nav-dot"></span> Attendance</a>
    </nav>
    <div class="sb-foot">
      <div class="user-chip">
        <div class="user-av" id="userAv">?</div>
        <span class="user-em" id="userEmail">Loading...</span>
      </div>
      <button class="signout-btn" id="signoutBtn"><i class="fa-solid fa-right-from-bracket"></i> Sign out</button>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <h1>Roster</h1>
        <span class="page-meta" id="rosterCount">—</span>
      </div>
      <div class="topbar-right">
        <button class="tbtn" id="importBtn"><i class="fa-solid fa-file-arrow-up"></i> Import</button>
        <button class="tbtn" id="addAthleteBtn"><i class="fa-solid fa-user-plus"></i> Add</button>
        <button class="tbtn accent" id="exportBtn"><i class="fa-solid fa-download"></i> Export</button>
      </div>
    </div>

    <div class="filter-bar">
      <button class="fpill active" data-filter="all" onclick="setFilter(this,'all')">All</button>
      <div class="fsep"></div>
      <button class="fpill" data-filter="Boys" onclick="setFilter(this,'team:Boys')">Boys</button>
      <button class="fpill" data-filter="Girls" onclick="setFilter(this,'team:Girls')">Girls</button>
      <div class="fsep"></div>
      <button class="fpill" data-filter="Active" onclick="setFilter(this,'status:Active')">Active</button>
      <button class="fpill" data-filter="Suspended" onclick="setFilter(this,'status:Suspended')">Suspended</button>
      <button class="fpill" data-filter="Ineligible" onclick="setFilter(this,'status:Ineligible')">Ineligible</button>
      <button class="fpill" data-filter="Cut" onclick="setFilter(this,'status:Cut')">Cut</button>
      <div class="fsep"></div>
      <button class="fpill" data-filter="Cross Country" onclick="setFilter(this,'season:Cross Country')">XC</button>
      <button class="fpill" data-filter="Indoor Track & Field" onclick="setFilter(this,'season:Indoor Track & Field')">Indoor</button>
      <button class="fpill" data-filter="Outdoor Track & Field" onclick="setFilter(this,'season:Outdoor Track & Field')">Outdoor</button>
      <div class="fsep"></div>
      <button class="fpill" data-filter="No Physical" onclick="setFilter(this,'paperwork:No Physical')">No Physical</button>
      <button class="fpill" data-filter="Missing Docs" onclick="setFilter(this,'paperwork:Missing Docs')">Missing Docs</button>
      <div class="search-wrap"><i class="fa-solid fa-magnifying-glass"></i><input type="text" id="searchInput" placeholder="Search..." /></div>
    </div>

    <div class="tbl-wrap">
      <table class="roster-tbl">
        <thead>
          <tr>
            <th style="width:220px">ATHLETE</th>
            <th>GR</th>
            <th>TEAM</th>
            <th>EVENT</th>
            <th>STATUS</th>
            <th>PAPERWORK</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="rosterBody">
          <tr><td colspan="7" class="loading-cell"><i class="fa-solid fa-paw fa-spin"></i> Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </main>
</div>

<!-- ADD / EDIT MODAL (shared) -->
<div class="overlay hidden" id="athleteFormOverlay">
  <div class="modal modal-form">
    <div class="modal-hd">
      <div><div class="modal-title" id="formModalTitle">Add Athlete</div><div class="modal-sub" id="formModalSub">Manually add to roster</div></div>
      <button class="modal-x" onclick="closeAthleteForm()"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">

      <div class="form-section-label">Athlete Details</div>
      <div class="frow">
        <div class="fg"><label>First Name *</label><input type="text" id="f_fn" /></div>
        <div class="fg"><label>Last Name *</label><input type="text" id="f_ln" /></div>
      </div>
      <div class="frow">
        <div class="fg"><label>Grade *</label>
          <select id="f_gr">
            <option value="">—</option>
            <option value="9">9th Grade</option>
            <option value="10">10th Grade</option>
            <option value="11">11th Grade</option>
            <option value="12">12th Grade</option>
          </select>
        </div>
        <div class="fg"><label>Birthday</label><input type="date" id="f_bday" /></div>
      </div>
      <div class="frow">
        <div class="fg"><label>Athlete Email *</label><input type="email" id="f_em" placeholder="athlete@example.com" /></div>
        <div class="fg"><label>Athlete Phone *</label><input type="tel" id="f_ph" placeholder="(555) 555-5555" /></div>
      </div>
      <div class="frow">
        <div class="fg"><label>Team *</label>
          <select id="f_tm"><option value="">—</option><option>Boys</option><option>Girls</option></select>
        </div>
        <div class="fg"><label>Athlete Type *</label>
          <select id="f_type"><option value="New Athlete">New Athlete</option><option value="Returning Athlete">Returning Athlete</option></select>
        </div>
      </div>

      <div class="form-section-label">Season &amp; Events</div>
      <div class="fg"><label>Season(s) *</label>
        <div class="check-row">
          <label class="ck"><input type="checkbox" name="f_s" value="Cross Country" /> Cross Country</label>
          <label class="ck"><input type="checkbox" name="f_s" value="Indoor Track & Field" /> Indoor T&F</label>
          <label class="ck"><input type="checkbox" name="f_s" value="Outdoor Track & Field" /> Outdoor T&F</label>
        </div>
      </div>
      <div class="frow">
        <div class="fg"><label>Event Group</label>
          <select id="f_ev"><option value="">—</option><option>Sprints</option><option>Distance</option><option>Throws</option></select>
        </div>
        <div class="fg"><label>Sprint Add-ons</label>
          <div class="check-row" style="margin-top:6px;">
            <label class="ck"><input type="checkbox" name="f_sa" value="Hurdles" /> Hurdles</label>
            <label class="ck"><input type="checkbox" name="f_sa" value="Jumps" /> Jumps</label>
          </div>
        </div>
      </div>

      <div class="form-section-label">Academic Background</div>
      <div class="fg"><label>Middle School *</label>
        <select id="f_ms">
          <option value="">Select Middle School...</option>
          <option value="Brookland Middle">Brookland Middle</option>
          <option value="Elko Middle">Elko Middle</option>
          <option value="Fairfield Middle">Fairfield Middle</option>
          <option value="George H. Moody Middle">George H. Moody Middle</option>
          <option value="Holman Middle">Holman Middle</option>
          <option value="Hungary Creek Middle">Hungary Creek Middle</option>
          <option value="L. Douglas Wilder Middle">L. Douglas Wilder Middle</option>
          <option value="Pocohontas Middle">Pocohontas Middle</option>
          <option value="Quioccasin Middle">Quioccasin Middle</option>
          <option value="John Rolfe Middle">John Rolfe Middle</option>
          <option value="Short Pump Middle">Short Pump Middle</option>
          <option value="Tuckahoe Middle">Tuckahoe Middle</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div class="fg hidden" id="f_ms_other_wrap"><label>Other Middle School *</label><input type="text" id="f_ms_other" placeholder="School name" /></div>
      <div class="frow">
        <div class="fg"><label>Specialty Center?</label>
          <select id="f_spec"><option value="no">No</option><option value="yes">Yes</option></select>
        </div>
        <div class="fg hidden" id="f_spec_prog_wrap"><label>Program</label>
          <select id="f_spec_prog">
            <option value="">Select...</option>
            <option value="Advance College Academy">Advance College Academy</option>
            <option value="International Baccalaureate">International Baccalaureate</option>
            <option value="Spanish Language Immersion">Spanish Language Immersion</option>
          </select>
        </div>
      </div>

      <div class="form-section-label">Prior Activities</div>
      <div class="fg"><label>Has participated in other activities this year?</label>
        <select id="f_hact"><option value="no">No</option><option value="yes">Yes</option></select>
      </div>
      <div class="fg hidden" id="f_activities_wrap">
        <label>Select all that apply</label>
        <div class="activities-grid">
          <label class="ck"><input type="checkbox" name="f_act" value="Basketball" /> Basketball</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Competition Cheer" /> Competition Cheer</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Dance Team" /> Dance Team</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Debate" /> Debate</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Field Hockey" /> Field Hockey</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Football" /> Football</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Forensics" /> Forensics</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Golf" /> Golf</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Gymnastics" /> Gymnastics</label>
          <label class="ck"><input type="checkbox" name="f_act" value="JROTC" /> JROTC</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Marching Band" /> Marching Band</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Sideline Cheer" /> Sideline Cheer</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Step Team" /> Step Team</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Swim" /> Swim</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Volleyball" /> Volleyball</label>
          <label class="ck"><input type="checkbox" name="f_act" value="Wrestling" /> Wrestling</label>
        </div>
      </div>

      <div class="form-section-label">Parent / Guardian</div>
      <div class="fg"><label>Parent / Guardian 1 Name *</label><input type="text" id="f_p1n" /></div>
      <div class="frow">
        <div class="fg"><label>Parent 1 Phone *</label><input type="tel" id="f_p1p" placeholder="(555) 555-5555" /></div>
        <div class="fg"><label>Parent 1 Email *</label><input type="email" id="f_p1e" placeholder="parent@example.com" /></div>
      </div>
      <div class="fg">
        <label class="ck" style="text-transform:none;letter-spacing:normal;font-weight:500;">
          <input type="checkbox" id="f_add_p2" onchange="toggleP2()" /> Add second parent / guardian
        </label>
      </div>
      <div class="hidden" id="f_p2_wrap">
        <div class="fg"><label>Parent / Guardian 2 Name</label><input type="text" id="f_p2n" /></div>
        <div class="frow">
          <div class="fg"><label>Parent 2 Phone</label><input type="tel" id="f_p2p" placeholder="(555) 555-5555" /></div>
          <div class="fg"><label>Parent 2 Email</label><input type="email" id="f_p2e" placeholder="parent@example.com" /></div>
        </div>
      </div>

      <div class="form-section-label">Notes</div>
      <div class="fg">
        <label>Additional Information <span style="font-weight:400;color:var(--muted)">(optional, max 256 chars)</span></label>
        <textarea id="f_notes" maxlength="256" rows="3" placeholder="Previous athletic experience, anything else we should know..."></textarea>
        <div style="text-align:right;font-size:10px;color:var(--muted);margin-top:3px;"><span id="f_notes_count">0</span>/256</div>
      </div>

      <div class="form-error hidden" id="athleteFormError"></div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeAthleteForm()">Cancel</button>
        <button class="btn-primary" id="athleteFormSaveBtn"><i class="fa-solid fa-check"></i> Save Athlete</button>
      </div>
    </div>
  </div>
</div>

<!-- IMPORT MODAL -->
<div class="overlay hidden" id="importOverlay">
  <div class="modal">
    <div class="modal-hd">
      <div><div class="modal-title">Import CSV</div><div class="modal-sub">Bulk add athletes</div></div>
      <button class="modal-x" onclick="closeOverlay('importOverlay')"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <div class="template-bar">
        <i class="fa-solid fa-file-csv"></i>
        <div>
          <div class="template-label">Need the format?</div>
          <button class="btn-link" id="downloadTemplateBtn">Download CSV template</button>
        </div>
      </div>
      <div class="upload-area" id="uploadArea">
        <i class="fa-solid fa-cloud-arrow-up"></i>
        <p>Drag & drop or <label class="btn-link" style="cursor:pointer;">browse<input type="file" id="csvFileInput" accept=".csv" style="display:none;" /></label></p>
      </div>
      <div class="hidden" id="importPreview">
        <div class="preview-hd">
          <span id="previewCount"></span>
          <button class="btn-link" onclick="clearImport()">Clear</button>
        </div>
        <div class="preview-scroll">
          <table class="preview-tbl" id="previewTable"></table>
        </div>
      </div>
      <div class="form-error hidden" id="importError"></div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="closeOverlay('importOverlay')">Cancel</button>
        <button class="btn-primary hidden" id="importSaveBtn"><i class="fa-solid fa-file-arrow-up"></i> Import</button>
      </div>
    </div>
  </div>
</div>

<!-- ATHLETE DOSSIER MODAL -->
<div class="overlay hidden" id="dossierOverlay" onclick="overlayClick(event,'dossierOverlay')">
  <div class="modal modal-wide" id="dossierModal">
    <div id="dossierContent"></div>
  </div>
</div>

<script type="module">
import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';

(async () => {

const supabase = createClient(
  'https://kbewlrudpdqmvdsbljen.supabase.co',
  'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtiZXdscnVkcGRxbXZkc2JsamVuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2ODkxNDQsImV4cCI6MjA4OTI2NTE0NH0.RYeII_T640_x4AVrThyYgy3nJcHfHc6iUVkWy2R9GgI'
);

const EV_COLOR = { Sprints:'ev-sprints', Distance:'ev-distance', Throws:'ev-throws' };

// ── Constants (declared early so all functions can access them) ──────────────
const PAPERWORK_FIELDS = [
  { key:'physical_exam',       label:'Physical Exam' },
  { key:'activities_contract', label:'Activities Contract' },
  { key:'concussion_form',     label:'Concussion Form' },
  { key:'heat_illness_form',   label:'Heat Illness Form' },
  { key:'cardiac_arrest_form', label:'Cardiac Arrest Form' },
  { key:'emergency_card',      label:'Emergency Card' },
  { key:'team_contract',       label:'Team Contract' },
];

// ── Auth ────────────────────────────────────────────────────────────────────
const { data: { session } } = await supabase.auth.getSession();
if (!session) { window.location.href = '/dashboard'; return; }

const { data: profile } = await supabase.from('profiles').select('*').eq('id', session.user.id).single();
const email = session.user.email;
document.getElementById('userEmail').textContent = email;
document.getElementById('userAv').textContent = email.slice(0,2).toUpperCase();

if (profile?.role === 'manager') {
  document.getElementById('rosterBody').innerHTML = '<tr><td colspan="7" class="loading-cell"><i class="fa-solid fa-lock"></i> Managers cannot view the full roster.</td></tr>';
  document.getElementById('rosterCount').textContent = '';
  ['exportBtn','addAthleteBtn','importBtn'].forEach(id => document.getElementById(id).style.display = 'none');
  return;
}

// ── Drawer ───────────────────────────────────────────────────────────────────
window.openDrawer  = () => { document.getElementById('sidebar').classList.add('open'); document.getElementById('drawerOverlay').classList.add('visible'); document.body.style.overflow='hidden'; };
window.closeDrawer = () => { document.getElementById('sidebar').classList.remove('open'); document.getElementById('drawerOverlay').classList.remove('visible'); document.body.style.overflow=''; };

// ── Sign out ─────────────────────────────────────────────────────────────────
document.getElementById('signoutBtn').addEventListener('click', async () => { await supabase.auth.signOut(); window.location.href = '/dashboard'; });

// ── Load data ────────────────────────────────────────────────────────────────
let allAthletes = [];
let activeFilter = 'all';

async function loadRoster() {
  const { data, error } = await supabase.from('athlete_summary').select('*').order('last_name', { ascending: true });
  if (error) {
    document.getElementById('rosterBody').innerHTML = `<tr><td colspan="7" class="loading-cell">Error: ${error.message}</td></tr>`;
    return;
  }
  allAthletes = data || [];
  applyFilters();
}

await loadRoster();

// ── Filter system ─────────────────────────────────────────────────────────────
window.setFilter = (btn, filter) => {
  document.querySelectorAll('.fpill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  activeFilter = filter;
  applyFilters();
};

document.getElementById('searchInput').addEventListener('input', applyFilters);

function applyFilters() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const filtered = allAthletes.filter(a => {
    if (activeFilter !== 'all') {
      const [type, val] = activeFilter.split(':');
      if (type === 'team'      && a.team !== val)                    return false;
      if (type === 'status'    && a.status !== val)                  return false;
      if (type === 'season'    && !(a.season||[]).includes(val))     return false;
      if (type === 'paperwork' && a.paperwork_status !== val)        return false;
    }
    if (search) {
      const name = `${a.first_name} ${a.last_name}`.toLowerCase();
      if (!name.includes(search) && !(a.email||'').toLowerCase().includes(search)) return false;
    }
    return true;
  });
  renderTable(filtered);
}

// ── Render ────────────────────────────────────────────────────────────────────
function paperworkBadge(status) {
  if (status === 'No Physical')      return '<span class="badge badge-danger">No Physical</span>';
  if (status === 'Missing Docs')     return '<span class="badge badge-warn">Missing Docs</span>';
  if (status === 'Paperwork Complete') return '<span class="badge badge-ok">Complete</span>';
  return '<span class="badge badge-neutral">—</span>';
}

function statusBadge(status) {
  const map = { Active:'badge-active', Suspended:'badge-warn', Ineligible:'badge-danger', Quit:'badge-neutral', Cut:'badge-neutral' };
  return `<span class="badge ${map[status]||'badge-neutral'}">${status}</span>`;
}

function renderTable(athletes) {
  const tbody  = document.getElementById('rosterBody');
  const countEl = document.getElementById('rosterCount');
  countEl.textContent = `${athletes.length} athlete${athletes.length !== 1 ? 's' : ''}`;

  if (!athletes.length) {
    tbody.innerHTML = '<tr><td colspan="7" class="loading-cell">No athletes match.</td></tr>';
    return;
  }

  tbody.innerHTML = athletes.map(a => {
    const dimmed = ['Quit','Cut'].includes(a.status) ? 'row-dim' : '';
    return `<tr class="${dimmed}" onclick="openDossier('${a.id}')">
      <td><div class="name-cell">
        <div class="av ${EV_COLOR[a.event_group]||'ev-default'}">${a.first_name[0]}${a.last_name[0]}</div>
        <div><div class="name-main">${a.last_name}, ${a.first_name}</div><div class="name-sub">Gr. ${a.grade} &middot; ${a.team}</div></div>
      </div></td>
      <td>${a.grade}</td>
      <td><span class="badge ${a.team==='Boys'?'badge-boys':'badge-girls'}">${a.team}</span></td>
      <td>${a.event_group ? `<span class="badge ${EV_COLOR[a.event_group]||''}-badge">${a.event_group}</span>` : '<span class="muted">—</span>'}</td>
      <td>${statusBadge(a.status||'Active')}</td>
      <td>${paperworkBadge(a.paperwork_status)}</td>
      <td onclick="event.stopPropagation()"><button class="row-btn" onclick="openDossier('${a.id}')"><i class="fa-solid fa-pen-to-square"></i></button></td>
    </tr>`;
  }).join('');
}

// ── Dossier modal ─────────────────────────────────────────────────────────────


let currentAthleteId = null;

window.openDossier = async (id) => {
  currentAthleteId = id;
  const a = allAthletes.find(x => x.id === id);
  if (!a) return;

  document.getElementById('dossierContent').innerHTML = buildDossierView(a);
  document.getElementById('dossierOverlay').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
};

function buildDossierView(a) {
  const pw = PAPERWORK_FIELDS.map(f => `
    <div class="pw-item">
      <span class="pw-label">${f.label}</span>
      ${a[f.key] ? '<span class="pw-check"><i class="fa-solid fa-check"></i></span>' : '<span class="pw-missing"><i class="fa-solid fa-xmark"></i></span>'}
    </div>`).join('');

  const seasons = (a.season||[]).map(s => {
    const cls = s==='Cross Country'?'badge-xc':s.includes('Indoor')?'badge-indoor':'badge-outdoor';
    const lbl = s==='Cross Country'?'XC':s.includes('Indoor')?'Indoor':'Outdoor';
    return `<span class="badge ${cls}">${lbl}</span>`;
  }).join('');

  return `
    <div class="dossier-header">
      <div class="dossier-av ${EV_COLOR[a.event_group]||'ev-default'}">${a.first_name[0]}${a.last_name[0]}</div>
      <div class="dossier-name-block">
        <div class="dossier-name">${a.first_name} ${a.last_name}</div>
        <div class="dossier-badges">
          ${statusBadge(a.status||'Active')}
          ${paperworkBadge(a.paperwork_status)}
          ${a.event_group ? `<span class="badge ev-${(a.event_group||'').toLowerCase()}-badge">${a.event_group}</span>` : ''}
          <span class="badge badge-neutral">Grade ${a.grade}</span>
          <span class="badge ${a.team==='Boys'?'badge-boys':'badge-girls'}">${a.team}</span>
        </div>
      </div>
      <div class="dossier-actions">
        <button class="tbtn" onclick="switchToDossierEdit()"><i class="fa-solid fa-pen"></i> Edit</button>
        <button class="modal-x" onclick="closeDossier()"><i class="fa-solid fa-xmark"></i></button>
      </div>
    </div>

    <div class="dossier-grid">
      <div class="dossier-section">
        <div class="ds-label">CONTACT</div>
        <div class="ds-row"><span>Email</span><span>${a.email}</span></div>
        <div class="ds-row"><span>Phone</span><span>${a.phone}</span></div>
        ${a.birthday ? `<div class="ds-row"><span>Birthday</span><span>${a.birthday}</span></div>` : ''}
      </div>
      <div class="dossier-section">
        <div class="ds-label">SEASONS</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;padding-top:2px;">${seasons||'—'}</div>
      </div>
      <div class="dossier-section">
        <div class="ds-label">PARENT / GUARDIAN</div>
        <div class="ds-name">${a.parent1_name}</div>
        <div class="ds-row"><span>Phone</span><span>${a.parent1_phone}</span></div>
        <div class="ds-row"><span>Email</span><span>${a.parent1_email}</span></div>
      </div>
      <div class="dossier-section">
        <div class="ds-label">PAPERWORK</div>
        <div class="pw-grid">${pw}</div>
      </div>
    </div>
  `;
}

function buildDossierEdit(a) {
  const pwChecks = PAPERWORK_FIELDS.map(f => `
    <label class="pw-edit-item">
      <input type="checkbox" id="pw_${f.key}" ${a[f.key]?'checked':''} />
      <span>${f.label}</span>
    </label>`).join('');

  const statusOpts = ['Active','Suspended','Ineligible','Quit','Cut'].map(s =>
    `<option value="${s}" ${(a.status||'Active')===s?'selected':''}>${s}</option>`).join('');

  const evOpts = ['','Sprints','Distance','Throws'].map(v =>
    `<option value="${v}" ${(a.event_group||'')=== v?'selected':''}>${v||'—'}</option>`).join('');

  return `
    <div class="dossier-header">
      <div class="dossier-av ${EV_COLOR[a.event_group]||'ev-default'}">${a.first_name[0]}${a.last_name[0]}</div>
      <div class="dossier-name-block">
        <div class="dossier-name">${a.first_name} ${a.last_name}</div>
        <div class="dossier-badges"><span class="badge badge-neutral">Editing</span></div>
      </div>
      <div class="dossier-actions">
        <button class="tbtn" onclick="switchToDossierView('${a.id}')"><i class="fa-solid fa-arrow-left"></i> Back</button>
        <button class="modal-x" onclick="closeDossier()"><i class="fa-solid fa-xmark"></i></button>
      </div>
    </div>

    <div class="dossier-edit-body">
      <div class="dossier-edit-cols">
        <div>
          <div class="ds-label" style="margin-bottom:0.75rem;">ATHLETE INFO</div>
          <div class="frow"><div class="fg"><label>First Name</label><input type="text" id="e_fn" value="${a.first_name}" /></div><div class="fg"><label>Last Name</label><input type="text" id="e_ln" value="${a.last_name}" /></div></div>
          <div class="frow">
            <div class="fg"><label>Grade</label><select id="e_gr"><option>9</option><option>10</option><option>11</option><option>12</option></select></div>
            <div class="fg"><label>Team</label><select id="e_tm"><option>Boys</option><option>Girls</option></select></div>
          </div>
          <div class="fg" style="margin-bottom:0.75rem;"><label>Event Group</label><select id="e_ev">${evOpts}</select></div>
          <div class="fg" style="margin-bottom:0.75rem;"><label>Status</label><select id="e_st">${statusOpts}</select></div>
          <div class="fg"><label>Season(s)</label>
            <div class="check-row">
              <label class="ck"><input type="checkbox" name="e_s" value="Cross Country" ${(a.season||[]).includes('Cross Country')?'checked':''}/> XC</label>
              <label class="ck"><input type="checkbox" name="e_s" value="Indoor Track & Field" ${(a.season||[]).includes('Indoor Track & Field')?'checked':''}/> Indoor</label>
              <label class="ck"><input type="checkbox" name="e_s" value="Outdoor Track & Field" ${(a.season||[]).includes('Outdoor Track & Field')?'checked':''}/> Outdoor</label>
            </div>
          </div>
          <div class="frow"><div class="fg"><label>Email</label><input type="email" id="e_em" value="${a.email}" /></div><div class="fg"><label>Phone</label><input type="tel" id="e_ph" value="${a.phone}" /></div></div>
          <div class="fg"><label>Parent Name</label><input type="text" id="e_p1n" value="${a.parent1_name}" /></div>
          <div class="frow"><div class="fg"><label>Parent Phone</label><input type="tel" id="e_p1p" value="${a.parent1_phone}" /></div><div class="fg"><label>Parent Email</label><input type="email" id="e_p1e" value="${a.parent1_email}" /></div></div>
        </div>
        <div>
          <div class="ds-label" style="margin-bottom:0.75rem;">PAPERWORK</div>
          <div class="pw-edit-grid">${pwChecks}</div>
        </div>
      </div>
      <div class="form-error hidden" id="editError"></div>
      <div class="modal-actions" style="margin-top:1.25rem;">
        <button class="btn-cancel" onclick="switchToDossierView('${a.id}')">Cancel</button>
        <button class="btn-primary" id="saveDossierBtn"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
      </div>
    </div>
  `;
}

window.switchToDossierEdit = () => {
  const a = allAthletes.find(x => x.id === currentAthleteId);
  if (!a) return;
  closeDossier();
  openAthleteForm('edit', a);
};

window.switchToDossierView = (id) => {
  const a = allAthletes.find(x => x.id === (id || currentAthleteId));
  if (!a) return;
  document.getElementById('dossierContent').innerHTML = buildDossierView(a);
};

window.closeDossier = () => {
  document.getElementById('dossierOverlay').classList.add('hidden');
  document.body.style.overflow = '';
};

window.overlayClick = (e, id) => {
  if (e.target === document.getElementById(id)) {
    document.getElementById(id).classList.add('hidden');
    document.body.style.overflow = '';
  }
};

async function saveDossier() {
  const btn = document.getElementById('saveDossierBtn');
  const errEl = document.getElementById('editError');
  errEl.classList.add('hidden');
  btn.disabled = true;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

  const season = [...document.querySelectorAll('input[name="e_s"]:checked')].map(i => i.value);

  // Update registration
  const { error: regErr } = await supabase.from('registrations').update({
    first_name:    document.getElementById('e_fn').value.trim(),
    last_name:     document.getElementById('e_ln').value.trim(),
    grade:         parseInt(document.getElementById('e_gr').value),
    team:          document.getElementById('e_tm').value,
    event_group:   document.getElementById('e_ev').value || null,
    email:         document.getElementById('e_em').value.trim(),
    phone:         document.getElementById('e_ph').value.trim(),
    season,
    parent1_name:  document.getElementById('e_p1n').value.trim(),
    parent1_phone: document.getElementById('e_p1p').value.trim(),
    parent1_email: document.getElementById('e_p1e').value.trim(),
  }).eq('id', currentAthleteId);

  if (regErr) {
    errEl.textContent = regErr.message;
    errEl.classList.remove('hidden');
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
    return;
  }

  // Update athlete_records
  const pwUpdate = {};
  PAPERWORK_FIELDS.forEach(f => {
    pwUpdate[f.key] = document.getElementById(`pw_${f.key}`)?.checked || false;
  });
  pwUpdate.status = document.getElementById('e_st').value;
  pwUpdate.status_changed_by = session.user.id;

  const { error: recErr } = await supabase.from('athlete_records')
    .update(pwUpdate)
    .eq('athlete_id', currentAthleteId);

  if (recErr) {
    errEl.textContent = recErr.message;
    errEl.classList.remove('hidden');
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
    return;
  }

  await loadRoster();
  closeDossier();
}

// ── Add athlete ───────────────────────────────────────────────────────────────
window.closeOverlay = (id) => { document.getElementById(id).classList.add('hidden'); document.body.style.overflow = ''; };

// ── Unified athlete form (add + edit) ────────────────────────────────────────
let formMode = 'add'; // 'add' or 'edit'

function openAthleteForm(mode, athlete) {
  formMode = mode;
  const title = document.getElementById('formModalTitle');
  const sub   = document.getElementById('formModalSub');
  title.textContent = mode === 'add' ? 'Add Athlete' : 'Edit Athlete';
  sub.textContent   = mode === 'add' ? 'Manually add to roster' : 'Update athlete information';
  document.getElementById('athleteFormSaveBtn').innerHTML = mode === 'add'
    ? '<i class="fa-solid fa-check"></i> Save Athlete'
    : '<i class="fa-solid fa-floppy-disk"></i> Save Changes';

  // Reset form
  document.getElementById('athleteFormOverlay').querySelectorAll('input[type=text],input[type=email],input[type=tel],input[type=date],select,textarea').forEach(el => el.value = '');
  document.querySelectorAll('input[name=f_s],input[name=f_sa],input[name=f_act]').forEach(c => c.checked = false);
  document.getElementById('f_add_p2').checked = false;
  document.getElementById('f_p2_wrap').classList.add('hidden');
  document.getElementById('f_ms_other_wrap').classList.add('hidden');
  document.getElementById('f_spec_prog_wrap').classList.add('hidden');
  document.getElementById('f_activities_wrap').classList.add('hidden');
  document.getElementById('f_notes_count').textContent = '0';
  document.getElementById('athleteFormError').classList.add('hidden');

  if (mode === 'edit' && athlete) {
    document.getElementById('f_fn').value    = athlete.first_name || '';
    document.getElementById('f_ln').value    = athlete.last_name  || '';
    document.getElementById('f_gr').value    = String(athlete.grade || '');
    document.getElementById('f_bday').value  = athlete.birthday   || '';
    document.getElementById('f_em').value    = athlete.email      || '';
    document.getElementById('f_ph').value    = athlete.phone      || '';
    document.getElementById('f_tm').value    = athlete.team       || '';
    document.getElementById('f_type').value  = athlete.athlete_type || 'New Athlete';
    document.getElementById('f_ev').value    = athlete.event_group  || '';
    document.getElementById('f_ms').value    = athlete.middle_school || '';
    document.getElementById('f_spec').value  = athlete.is_specialty ? 'yes' : 'no';
    document.getElementById('f_hact').value  = athlete.has_activities ? 'yes' : 'no';
    document.getElementById('f_notes').value = athlete.notes || '';
    document.getElementById('f_notes_count').textContent = (athlete.notes || '').length;
    document.getElementById('f_p1n').value = athlete.parent1_name  || '';
    document.getElementById('f_p1p').value = athlete.parent1_phone || '';
    document.getElementById('f_p1e').value = athlete.parent1_email || '';

    if (athlete.parent2_name) {
      document.getElementById('f_add_p2').checked = true;
      document.getElementById('f_p2_wrap').classList.remove('hidden');
      document.getElementById('f_p2n').value = athlete.parent2_name  || '';
      document.getElementById('f_p2p').value = athlete.parent2_phone || '';
      document.getElementById('f_p2e').value = athlete.parent2_email || '';
    }

    (athlete.season || []).forEach(s => {
      const cb = document.querySelector(`input[name=f_s][value="${s}"]`);
      if (cb) cb.checked = true;
    });
    (athlete.sprint_addons || []).forEach(s => {
      const cb = document.querySelector(`input[name=f_sa][value="${s}"]`);
      if (cb) cb.checked = true;
    });
    (athlete.activities || []).forEach(a => {
      const cb = document.querySelector(`input[name=f_act][value="${a}"]`);
      if (cb) cb.checked = true;
    });

    if (athlete.middle_school === 'Other') document.getElementById('f_ms_other_wrap').classList.remove('hidden');
    if (athlete.is_specialty)             document.getElementById('f_spec_prog_wrap').classList.remove('hidden');
    if (athlete.has_activities)           document.getElementById('f_activities_wrap').classList.remove('hidden');
    if (athlete.specialty_program)        document.getElementById('f_spec_prog').value = athlete.specialty_program;
    if (athlete.other_middle_school)      document.getElementById('f_ms_other').value  = athlete.other_middle_school;
  }

  document.getElementById('athleteFormOverlay').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}

window.closeAthleteForm = () => { document.getElementById('athleteFormOverlay').classList.add('hidden'); document.body.style.overflow = ''; };
window.toggleP2 = () => { document.getElementById('f_p2_wrap').classList.toggle('hidden', !document.getElementById('f_add_p2').checked); };

// Conditional field toggles in the form
document.getElementById('f_ms').addEventListener('change', e => {
  document.getElementById('f_ms_other_wrap').classList.toggle('hidden', e.target.value !== 'Other');
});
document.getElementById('f_spec').addEventListener('change', e => {
  document.getElementById('f_spec_prog_wrap').classList.toggle('hidden', e.target.value !== 'yes');
});
document.getElementById('f_hact').addEventListener('change', e => {
  document.getElementById('f_activities_wrap').classList.toggle('hidden', e.target.value !== 'yes');
});
document.getElementById('f_notes').addEventListener('input', e => {
  document.getElementById('f_notes_count').textContent = e.target.value.length;
});

document.getElementById('addAthleteBtn').addEventListener('click', () => openAthleteForm('add'));

document.getElementById('athleteFormSaveBtn').addEventListener('click', async () => {
  const btn   = document.getElementById('athleteFormSaveBtn');
  const errEl = document.getElementById('athleteFormError');
  errEl.classList.add('hidden');

  const fn   = document.getElementById('f_fn').value.trim();
  const ln   = document.getElementById('f_ln').value.trim();
  const gr   = parseInt(document.getElementById('f_gr').value);
  const tm   = document.getElementById('f_tm').value;
  const em   = document.getElementById('f_em').value.trim();
  const ph   = document.getElementById('f_ph').value.trim();
  const p1n  = document.getElementById('f_p1n').value.trim();
  const p1p  = document.getElementById('f_p1p').value.trim();
  const p1e  = document.getElementById('f_p1e').value.trim();
  const ev   = document.getElementById('f_ev').value || null;
  const s    = [...document.querySelectorAll('input[name=f_s]:checked')].map(i => i.value);
  const ms   = document.getElementById('f_ms').value;
  const mso  = document.getElementById('f_ms_other').value.trim();
  const spec = document.getElementById('f_spec').value === 'yes';
  const sp   = document.getElementById('f_spec_prog').value || null;
  const hact = document.getElementById('f_hact').value === 'yes';
  const acts = [...document.querySelectorAll('input[name=f_act]:checked')].map(i => i.value);
  const sa   = [...document.querySelectorAll('input[name=f_sa]:checked')].map(i => i.value);
  const bday = document.getElementById('f_bday').value || null;
  const type = document.getElementById('f_type').value;
  const notes = document.getElementById('f_notes').value.trim() || null;
  const p2n  = document.getElementById('f_p2n').value.trim() || null;
  const p2p  = document.getElementById('f_p2p').value.trim() || null;
  const p2e  = document.getElementById('f_p2e').value.trim() || null;

  if (!fn||!ln||!gr||!tm||!em||!ph||!p1n||!p1p||!p1e||!ms) {
    errEl.textContent='Please fill in all required fields.'; errEl.classList.remove('hidden'); return;
  }
  if (!s.length) { errEl.textContent='Select at least one season.'; errEl.classList.remove('hidden'); return; }
  if (ms==='Other'&&!mso) { errEl.textContent='Please specify the middle school.'; errEl.classList.remove('hidden'); return; }

  btn.disabled=true;
  btn.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

  const record = {
    athlete_type: type, first_name:fn, last_name:ln, grade:gr, team:tm,
    email:em, phone:ph, season:s, event_group:ev, sprint_addons:sa,
    birthday:bday, middle_school:ms, other_middle_school:mso||null,
    is_specialty:spec, specialty_program:sp, has_activities:hact, activities:acts,
    parent1_name:p1n, parent1_phone:p1p, parent1_email:p1e,
    parent2_name:p2n, parent2_phone:p2p, parent2_email:p2e,
    notes,
  };

  let error;
  if (formMode === 'add') {
    ({ error } = await supabase.from('registrations').insert([record]));
  } else {
    ({ error } = await supabase.from('registrations').update(record).eq('id', currentAthleteId));
  }

  if (error) {
    errEl.textContent=error.message; errEl.classList.remove('hidden');
    btn.disabled=false;
    btn.innerHTML = formMode==='add' ? '<i class="fa-solid fa-check"></i> Save Athlete' : '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
    return;
  }

  await loadRoster();
  closeAthleteForm();
  if (formMode==='edit') closeDossier();
  btn.disabled=false;
  btn.innerHTML = formMode==='add' ? '<i class="fa-solid fa-check"></i> Save Athlete' : '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
});

// ── Export CSV ────────────────────────────────────────────────────────────────
document.getElementById('exportBtn').addEventListener('click', () => {
  const headers = ['Last Name','First Name','Grade','Team','Season','Event','Status','Paperwork','Email','Phone','Parent','Parent Phone','Parent Email'];
  const rows = allAthletes.map(a => [
    a.last_name, a.first_name, a.grade, a.team,
    (a.season||[]).join('; '), a.event_group||'',
    a.status||'', a.paperwork_status||'',
    a.email, a.phone, a.parent1_name, a.parent1_phone, a.parent1_email,
  ]);
  const csv = [headers,...rows].map(r=>r.map(v=>`"${String(v||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const url = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  const a = document.createElement('a'); a.href=url; a.download=`jrtxctf-roster-${new Date().toISOString().split('T')[0]}.csv`; a.click();
  URL.revokeObjectURL(url);
});

// ── Import CSV ────────────────────────────────────────────────────────────────
const CSV_HEADERS = ['first_name','last_name','grade','team','season (semicolon separated)','event_group','email','phone','parent1_name','parent1_phone','parent1_email'];

document.getElementById('importBtn').addEventListener('click', () => {
  document.getElementById('importOverlay').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
});

document.getElementById('downloadTemplateBtn').addEventListener('click', () => {
  const example = ['Jane','Smith','10','Girls','Cross Country; Outdoor Track & Field','Distance','jane@example.com','(555) 555-5555','Bob Smith','(555) 555-5556','bob@example.com'];
  const csv = [CSV_HEADERS,example].map(r=>r.map(v=>`"${v}"`).join(',')).join('\n');
  const url = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  const a = document.createElement('a'); a.href=url; a.download='jrtxctf-import-template.csv'; a.click();
  URL.revokeObjectURL(url);
});

const uploadArea = document.getElementById('uploadArea');
uploadArea.addEventListener('dragover', e=>{e.preventDefault();uploadArea.classList.add('drag-over');});
uploadArea.addEventListener('dragleave', ()=>uploadArea.classList.remove('drag-over'));
uploadArea.addEventListener('drop', e=>{e.preventDefault();uploadArea.classList.remove('drag-over');const f=e.dataTransfer.files[0];if(f)parseCSV(f);});
document.getElementById('csvFileInput').addEventListener('change', e=>{const f=e.target.files[0];if(f)parseCSV(f);});

let parsedAthletes = [];

function parseCSV(file) {
  const reader = new FileReader();
  reader.onload = e => {
    const lines = e.target.result.split('\n').filter(l=>l.trim());
    const headers = lines[0].split(',').map(h=>h.replace(/"/g,'').trim().toLowerCase());
    parsedAthletes = lines.slice(1).map(row => {
      const vals = row.match(/(".*?"|[^,]+)/g)||[];
      const clean = vals.map(v=>v.replace(/^"|"$/g,'').trim());
      const obj = {}; headers.forEach((h,i)=>{obj[h]=clean[i]||'';});
      const seasonRaw = obj['season (semicolon separated)']||obj['season']||'';
      return {
        athlete_type:'New Athlete',
        first_name:obj.first_name, last_name:obj.last_name,
        grade:parseInt(obj.grade)||null, team:obj.team,
        season:seasonRaw.split(';').map(s=>s.trim()).filter(Boolean),
        event_group:obj.event_group||null,
        email:obj.email, phone:obj.phone,
        parent1_name:obj.parent1_name, parent1_phone:obj.parent1_phone, parent1_email:obj.parent1_email,
        middle_school:'Other', is_specialty:false, has_activities:false,
      };
    }).filter(a=>a.first_name&&a.last_name);

    if (!parsedAthletes.length) {
      const e=document.getElementById('importError');e.textContent='No valid rows found.';e.classList.remove('hidden');return;
    }

    document.getElementById('previewCount').textContent = `${parsedAthletes.length} athlete${parsedAthletes.length!==1?'s':''} ready`;
    document.getElementById('previewTable').innerHTML = `
      <thead><tr>${['Name','Grade','Team','Season(s)','Event','Email'].map(h=>`<th>${h}</th>`).join('')}</tr></thead>
      <tbody>${parsedAthletes.map(a=>`<tr><td>${a.first_name} ${a.last_name}</td><td>${a.grade||'—'}</td><td>${a.team||'—'}</td><td>${(a.season||[]).join(', ')||'—'}</td><td>${a.event_group||'—'}</td><td>${a.email||'—'}</td></tr>`).join('')}</tbody>`;
    document.getElementById('importPreview').classList.remove('hidden');
    document.getElementById('importSaveBtn').classList.remove('hidden');
    uploadArea.classList.add('hidden');
  };
  reader.readAsText(file);
}

window.clearImport = () => {
  parsedAthletes=[];
  document.getElementById('importPreview').classList.add('hidden');
  document.getElementById('importSaveBtn').classList.add('hidden');
  document.getElementById('uploadArea').classList.remove('hidden');
  document.getElementById('csvFileInput').value='';
};

document.getElementById('importSaveBtn').addEventListener('click', async () => {
  const btn=document.getElementById('importSaveBtn');
  const errEl=document.getElementById('importError');
  btn.disabled=true; btn.innerHTML='<i class="fa-solid fa-spinner fa-spin"></i> Importing...';

  const { error } = await supabase.from('registrations').insert(parsedAthletes);
  if (error) { errEl.textContent='Import failed: '+error.message; errEl.classList.remove('hidden'); btn.disabled=false; btn.innerHTML='<i class="fa-solid fa-file-arrow-up"></i> Import'; return; }

  await loadRoster();
  closeOverlay('importOverlay');
  clearImport();
  btn.disabled=false; btn.innerHTML='<i class="fa-solid fa-file-arrow-up"></i> Import';
});

})(); // end IIFE
</script>
</body>
