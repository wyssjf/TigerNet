---
// src/pages/dashboard/roster.astro
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JRTXCTF | Roster</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  </head>
  <body>

    <!-- MOBILE TOPBAR -->
    <div class="mobile-topbar">
      <div class="mobile-brand">
        <i class="fa-solid fa-paw"></i>
        <span>JRTXCTF</span>
      </div>
      <button class="hamburger" id="hamburger" onclick="openDrawer()">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>

    <!-- DRAWER OVERLAY -->
    <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>

    <!-- SIDEBAR -->
    <div class="layout">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
          <i class="fa-solid fa-paw"></i>
          <span>JRTXCTF</span>
        </div>
        <nav class="sidebar-nav">
          <a href="/dashboard/roster" class="nav-item active">
            <i class="fa-solid fa-users"></i> Roster
          </a>
          <a href="/dashboard/attendance" class="nav-item">
            <i class="fa-solid fa-clipboard-check"></i> Attendance
          </a>
        </nav>
        <div class="sidebar-footer">
          <div class="user-info">
            <i class="fa-solid fa-circle-user"></i>
            <span id="userEmail">Loading...</span>
          </div>
          <button class="btn-signout" id="signoutBtn">
            <i class="fa-solid fa-right-from-bracket"></i> Sign Out
          </button>
        </div>
      </aside>

      <!-- MAIN -->
      <main class="main">
        <div class="page-header">
          <div>
            <h1>Roster</h1>
            <p class="page-sub" id="rosterCount">Loading athletes...</p>
          </div>
          <div class="header-actions">
            <button class="btn-secondary-action" id="importBtn">
              <i class="fa-solid fa-file-arrow-up"></i> Import CSV
            </button>
            <button class="btn-secondary-action" id="addAthleteBtn">
              <i class="fa-solid fa-user-plus"></i> Add Athlete
            </button>
            <button class="btn-export" id="exportBtn">
              <i class="fa-solid fa-download"></i> Export CSV
            </button>
          </div>
        </div>

        <!-- FILTERS -->
        <button class="filters-toggle" id="filtersToggle" onclick="toggleFilters()">
          <i class="fa-solid fa-sliders"></i> Filters & Search
          <i class="fa-solid fa-chevron-down" id="filtersChevron"></i>
        </button>
        <div class="filters" id="filtersPanel">
          <div class="filter-group">
            <label>Season</label>
            <select id="filterSeason">
              <option value="">All Seasons</option>
              <option value="Cross Country">Cross Country</option>
              <option value="Indoor Track & Field">Indoor T&F</option>
              <option value="Outdoor Track & Field">Outdoor T&F</option>
            </select>
          </div>
          <div class="filter-group">
            <label>Team</label>
            <select id="filterTeam">
              <option value="">All Teams</option>
              <option value="Boys">Boys</option>
              <option value="Girls">Girls</option>
            </select>
          </div>
          <div class="filter-group">
            <label>Event Group</label>
            <select id="filterEvent">
              <option value="">All Events</option>
              <option value="Sprints">Sprints</option>
              <option value="Distance">Distance</option>
              <option value="Throws">Throws</option>
            </select>
          </div>
          <div class="filter-group search-group">
            <label>Search</label>
            <div class="search-wrap">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input type="text" id="searchInput" placeholder="Name, email..." />
            </div>
          </div>
        </div>

        </div><!-- end filtersPanel -->

        <!-- TABLE -->
        <div class="table-wrap">
          <table class="roster-table" id="rosterTable">
            <thead>
              <tr>
                <th>Name</th>
                <th>Grade</th>
                <th>Team</th>
                <th>Season(s)</th>
                <th>Event</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Parent</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="rosterBody">
              <tr>
                <td colspan="9" class="loading-cell">
                  <i class="fa-solid fa-paw fa-spin"></i> Loading roster...
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="empty-state hidden" id="emptyState">
          <i class="fa-solid fa-filter-circle-xmark"></i>
          <p>No athletes match your filters.</p>
        </div>
      </main>
    </div>

    <!-- ADD ATHLETE MODAL -->
    <div class="modal-overlay hidden" id="addModalOverlay">
      <div class="modal modal-add">
        <button class="modal-close" onclick="document.getElementById('addModalOverlay').classList.add('hidden')">
          <i class="fa-solid fa-xmark"></i>
        </button>
        <h2 class="modal-title">Add Athlete</h2>
        <p class="modal-sub-title">Manually add an athlete to the roster.</p>

        <div class="add-form" id="addForm">
          <div class="form-row">
            <div class="form-group">
              <label>First Name *</label>
              <input type="text" id="add_firstName" placeholder="First name" />
            </div>
            <div class="form-group">
              <label>Last Name *</label>
              <input type="text" id="add_lastName" placeholder="Last name" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Grade *</label>
              <select id="add_grade">
                <option value="">Select...</option>
                <option value="9">9th</option>
                <option value="10">10th</option>
                <option value="11">11th</option>
                <option value="12">12th</option>
              </select>
            </div>
            <div class="form-group">
              <label>Team *</label>
              <select id="add_team">
                <option value="">Select...</option>
                <option value="Boys">Boys</option>
                <option value="Girls">Girls</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Season(s) *</label>
            <div class="check-row">
              <label class="check-label"><input type="checkbox" name="add_season" value="Cross Country" /> Cross Country</label>
              <label class="check-label"><input type="checkbox" name="add_season" value="Indoor Track & Field" /> Indoor T&F</label>
              <label class="check-label"><input type="checkbox" name="add_season" value="Outdoor Track & Field" /> Outdoor T&F</label>
            </div>
          </div>
          <div class="form-group">
            <label>Event Group</label>
            <select id="add_eventGroup">
              <option value="">Select...</option>
              <option value="Sprints">Sprints</option>
              <option value="Distance">Distance</option>
              <option value="Throws">Throws</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Athlete Email *</label>
              <input type="email" id="add_email" placeholder="athlete@example.com" />
            </div>
            <div class="form-group">
              <label>Athlete Phone *</label>
              <input type="tel" id="add_phone" placeholder="(555) 555-5555" />
            </div>
          </div>
          <div class="form-group">
            <label>Parent / Guardian Name *</label>
            <input type="text" id="add_parent1Name" placeholder="Full name" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Parent Phone *</label>
              <input type="tel" id="add_parent1Phone" placeholder="(555) 555-5555" />
            </div>
            <div class="form-group">
              <label>Parent Email *</label>
              <input type="email" id="add_parent1Email" placeholder="parent@example.com" />
            </div>
          </div>

          <div class="add-error hidden" id="addError"></div>

          <div class="add-actions">
            <button class="btn-cancel" onclick="document.getElementById('addModalOverlay').classList.add('hidden')">Cancel</button>
            <button class="btn-save" id="saveAthleteBtn">
              <i class="fa-solid fa-check"></i> Save Athlete
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- EDIT ATHLETE MODAL -->
    <div class="modal-overlay hidden" id="editModalOverlay">
      <div class="modal modal-add">
        <button class="modal-close" onclick="document.getElementById('editModalOverlay').classList.add('hidden')">
          <i class="fa-solid fa-xmark"></i>
        </button>
        <h2 class="modal-title">Edit Athlete</h2>
        <p class="modal-sub-title">Update athlete information.</p>

        <input type="hidden" id="edit_id" />
        <div class="add-form" id="editForm">
          <div class="form-row">
            <div class="form-group">
              <label>First Name *</label>
              <input type="text" id="edit_firstName" placeholder="First name" />
            </div>
            <div class="form-group">
              <label>Last Name *</label>
              <input type="text" id="edit_lastName" placeholder="Last name" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Grade *</label>
              <select id="edit_grade">
                <option value="">Select...</option>
                <option value="9">9th</option>
                <option value="10">10th</option>
                <option value="11">11th</option>
                <option value="12">12th</option>
              </select>
            </div>
            <div class="form-group">
              <label>Team *</label>
              <select id="edit_team">
                <option value="">Select...</option>
                <option value="Boys">Boys</option>
                <option value="Girls">Girls</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Season(s) *</label>
            <div class="check-row">
              <label class="check-label"><input type="checkbox" name="edit_season" value="Cross Country" /> Cross Country</label>
              <label class="check-label"><input type="checkbox" name="edit_season" value="Indoor Track & Field" /> Indoor T&F</label>
              <label class="check-label"><input type="checkbox" name="edit_season" value="Outdoor Track & Field" /> Outdoor T&F</label>
            </div>
          </div>
          <div class="form-group">
            <label>Event Group</label>
            <select id="edit_eventGroup">
              <option value="">Select...</option>
              <option value="Sprints">Sprints</option>
              <option value="Distance">Distance</option>
              <option value="Throws">Throws</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Athlete Email *</label>
              <input type="email" id="edit_email" placeholder="athlete@example.com" />
            </div>
            <div class="form-group">
              <label>Athlete Phone *</label>
              <input type="tel" id="edit_phone" placeholder="(555) 555-5555" />
            </div>
          </div>
          <div class="form-group">
            <label>Parent / Guardian Name *</label>
            <input type="text" id="edit_parent1Name" placeholder="Full name" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Parent Phone *</label>
              <input type="tel" id="edit_parent1Phone" placeholder="(555) 555-5555" />
            </div>
            <div class="form-group">
              <label>Parent Email *</label>
              <input type="email" id="edit_parent1Email" placeholder="parent@example.com" />
            </div>
          </div>

          <div class="add-error hidden" id="editError"></div>

          <div class="add-actions">
            <button class="btn-cancel" onclick="document.getElementById('editModalOverlay').classList.add('hidden')">Cancel</button>
            <button class="btn-save" id="updateAthleteBtn">
              <i class="fa-solid fa-floppy-disk"></i> Save Changes
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- IMPORT CSV MODAL -->
    <div class="modal-overlay hidden" id="importModalOverlay">
      <div class="modal modal-import">
        <button class="modal-close" onclick="document.getElementById('importModalOverlay').classList.add('hidden')">
          <i class="fa-solid fa-xmark"></i>
        </button>
        <h2 class="modal-title">Import CSV</h2>
        <p class="modal-sub-title">Upload a CSV file to bulk add athletes to the roster.</p>

        <div class="import-template">
          <i class="fa-solid fa-file-csv"></i>
          <div>
            <p class="template-label">Need the template?</p>
            <button class="btn-template" id="downloadTemplateBtn">Download CSV Template</button>
          </div>
        </div>

        <div class="upload-area" id="uploadArea">
          <i class="fa-solid fa-cloud-arrow-up"></i>
          <p>Drag & drop your CSV here, or</p>
          <label class="btn-browse">
            Browse file
            <input type="file" id="csvFileInput" accept=".csv" style="display:none;" />
          </label>
        </div>

        <div class="import-preview hidden" id="importPreview">
          <div class="preview-header">
            <span id="previewCount"></span>
            <button class="btn-clear-import" onclick="clearImport()">
              <i class="fa-solid fa-xmark"></i> Clear
            </button>
          </div>
          <div class="preview-table-wrap">
            <table class="preview-table" id="previewTable"></table>
          </div>
        </div>

        <div class="import-error hidden" id="importError"></div>

        <div class="add-actions">
          <button class="btn-cancel" onclick="document.getElementById('importModalOverlay').classList.add('hidden')">Cancel</button>
          <button class="btn-save hidden" id="importSaveBtn">
            <i class="fa-solid fa-file-arrow-up"></i> Import Athletes
          </button>
        </div>
      </div>
    </div>

    <!-- ATHLETE DETAIL MODAL -->
    <div class="modal-overlay hidden" id="modalOverlay" onclick="closeModal(event)">
      <div class="modal" id="modal">
        <button class="modal-close" onclick="closeModalDirect()">
          <i class="fa-solid fa-xmark"></i>
        </button>
        <div id="modalContent"></div>
      </div>
    </div>

    <script type="module">
      import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm';

      (async () => {

      const supabase = createClient(
        'https://kbewlrudpdqmvdsbljen.supabase.co',
        'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtiZXdscnVkcGRxbXZkc2JsamVuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM2ODkxNDQsImV4cCI6MjA4OTI2NTE0NH0.RYeII_T640_x4AVrThyYgy3nJcHfHc6iUVkWy2R9GgI'
      );

      // ── Auth guard ───────────────────────────────────────────────────────────
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) { window.location.href = '/dashboard'; }

      // Get profile to check role
      const { data: profile } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', session.user.id)
        .single();

      document.getElementById('userEmail').textContent = session.user.email;

      // Managers can't see the roster list
      if (profile?.role === 'manager') {
        document.getElementById('rosterBody').innerHTML = `
          <tr><td colspan="9" class="loading-cell">
            <i class="fa-solid fa-lock"></i>
            Managers do not have access to the full roster view.
          </td></tr>`;
        document.getElementById('rosterCount').textContent = '';
        document.getElementById('exportBtn').style.display = 'none';
        document.getElementById('addAthleteBtn').style.display = 'none';
        document.getElementById('importBtn').style.display = 'none';
        return;
      }

      // ── Drawer ───────────────────────────────────────────────────────────────
      window.openDrawer = () => {
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('drawerOverlay').classList.add('visible');
        document.body.style.overflow = 'hidden';
      };
      window.closeDrawer = () => {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('drawerOverlay').classList.remove('visible');
        document.body.style.overflow = '';
      };
      window.toggleFilters = () => {
        const panel   = document.getElementById('filtersPanel');
        const chevron = document.getElementById('filtersChevron');
        const isOpen  = panel.classList.toggle('filters-open');
        chevron.style.transform = isOpen ? 'rotate(180deg)' : '';
      };

      // ── Sign out ─────────────────────────────────────────────────────────────
      document.getElementById('signoutBtn').addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/dashboard';
      });

      // ── Load athletes ─────────────────────────────────────────────────────────
      let allAthletes = [];

      const { data: athletes, error } = await supabase
        .from('registrations')
        .select('*')
        .order('last_name', { ascending: true });

      if (error) {
        document.getElementById('rosterBody').innerHTML = `<tr><td colspan="9" class="loading-cell">Failed to load roster: ${error.message}</td></tr>`;
        return;
      }

      allAthletes = athletes || [];
      renderCards(allAthletes);

      // ── Filters ───────────────────────────────────────────────────────────────
      const filterSeason = document.getElementById('filterSeason');
      const filterTeam   = document.getElementById('filterTeam');
      const filterEvent  = document.getElementById('filterEvent');
      const searchInput  = document.getElementById('searchInput');

      function applyFilters() {
        const season = filterSeason.value;
        const team   = filterTeam.value;
        const event  = filterEvent.value;
        const search = searchInput.value.toLowerCase();

        const filtered = allAthletes.filter(a => {
          if (season && !a.season?.includes(season)) return false;
          if (team   && a.team !== team)              return false;
          if (event  && a.event_group !== event)      return false;
          if (search) {
            const name  = `${a.first_name} ${a.last_name}`.toLowerCase();
            const email = (a.email || '').toLowerCase();
            if (!name.includes(search) && !email.includes(search)) return false;
          }
          return true;
        });

        renderCards(filtered);
      }

      [filterSeason, filterTeam, filterEvent].forEach(el => el.addEventListener('change', applyFilters));
      searchInput.addEventListener('input', applyFilters);

      // ── Render table ──────────────────────────────────────────────────────────
      function renderCards(athletes) {
        const tbody   = document.getElementById('rosterBody');
        const empty   = document.getElementById('emptyState');
        const countEl = document.getElementById('rosterCount');

        countEl.textContent = `${athletes.length} athlete${athletes.length !== 1 ? 's' : ''}`;

        if (athletes.length === 0) {
          tbody.innerHTML = '';
          empty.classList.remove('hidden');
          return;
        }

        empty.classList.add('hidden');
        tbody.innerHTML = athletes.map(a => `
          <tr>
            <td>
              <div class="name-cell">
                <div class="athlete-avatar">${a.first_name[0]}${a.last_name[0]}</div>
                <span class="athlete-name-link" onclick="openModal('${a.id}')">${a.last_name}, ${a.first_name}</span>
              </div>
            </td>
            <td>${a.grade}</td>
            <td><span class="tag tag-team ${a.team === 'Boys' ? 'boys' : 'girls'}">${a.team}</span></td>
            <td class="season-cell">${(a.season || []).map(s => s.replace(' Track & Field', ' T&F')).join(', ') || '—'}</td>
            <td>${a.event_group ? `<span class="tag tag-event">${a.event_group}</span>` : '—'}</td>
            <td class="contact-cell">${a.email}</td>
            <td class="contact-cell">${a.phone}</td>
            <td class="contact-cell">${a.parent1_name}</td>
            <td>
              <div class="row-actions">
                <button class="btn-row-view" onclick="openModal('${a.id}')" title="View details">
                  <i class="fa-solid fa-eye"></i>
                </button>
                <button class="btn-row-edit" onclick="openEditModal('${a.id}')" title="Edit athlete">
                  <i class="fa-solid fa-pen"></i>
                </button>
              </div>
            </td>
          </tr>
        `).join('');
      }

      // ── Modal ─────────────────────────────────────────────────────────────────
      window.openModal = (id) => {
        const a = allAthletes.find(x => x.id === id);
        if (!a) return;

        const seasons = (a.season || []).join(', ') || '—';
        const activities = (a.activities || []).join(', ') || 'None';
        const addons = (a.sprint_addons || []).join(', ') || '';

        document.getElementById('modalContent').innerHTML = `
          <div class="modal-header">
            <div class="modal-avatar">${a.first_name[0]}${a.last_name[0]}</div>
            <div>
              <h2>${a.first_name} ${a.last_name}</h2>
              <p class="modal-sub">Grade ${a.grade} &nbsp;·&nbsp; ${a.team} Team &nbsp;·&nbsp; ${a.athlete_type}</p>
            </div>
          </div>

          <div class="modal-sections">
            <div class="modal-section">
              <h4>Contact</h4>
              <div class="detail-row"><span>Email</span><span>${a.email}</span></div>
              <div class="detail-row"><span>Phone</span><span>${a.phone}</span></div>
              <div class="detail-row"><span>Birthday</span><span>${a.birthday}</span></div>
            </div>

            <div class="modal-section">
              <h4>Athletics</h4>
              <div class="detail-row"><span>Season(s)</span><span>${seasons}</span></div>
              <div class="detail-row"><span>Event Group</span><span>${a.event_group || '—'}</span></div>
              ${addons ? `<div class="detail-row"><span>Also</span><span>${addons}</span></div>` : ''}
              <div class="detail-row"><span>Prior Activities</span><span>${activities}</span></div>
            </div>

            <div class="modal-section">
              <h4>Academic</h4>
              <div class="detail-row"><span>Middle School</span><span>${a.middle_school === 'Other' ? a.other_middle_school : a.middle_school}</span></div>
              <div class="detail-row"><span>Specialty</span><span>${a.is_specialty ? a.specialty_program : 'No'}</span></div>
            </div>

            <div class="modal-section">
              <h4>Parent / Guardian</h4>
              <div class="detail-row"><span>${a.parent1_name}</span><span>${a.parent1_phone} &nbsp;·&nbsp; ${a.parent1_email}</span></div>
              ${a.parent2_name ? `<div class="detail-row"><span>${a.parent2_name}</span><span>${a.parent2_phone} &nbsp;·&nbsp; ${a.parent2_email}</span></div>` : ''}
            </div>

            ${a.notes ? `
            <div class="modal-section">
              <h4>Notes</h4>
              <p class="notes-text">${a.notes}</p>
            </div>` : ''}
          </div>
        `;

        document.getElementById('modalOverlay').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      };

      window.closeModal = (e) => {
        if (e.target === document.getElementById('modalOverlay')) closeModalDirect();
      };
      window.closeModalDirect = () => {
        document.getElementById('modalOverlay').classList.add('hidden');
        document.body.style.overflow = '';
      };

      // ── Add Athlete button ────────────────────────────────────────────────────
      document.getElementById('addAthleteBtn').addEventListener('click', () => {
        document.getElementById('addModalOverlay').classList.remove('hidden');
      });

      // ── Save athlete ──────────────────────────────────────────────────────────
      document.getElementById('saveAthleteBtn').addEventListener('click', async () => {
        const btn       = document.getElementById('saveAthleteBtn');
        const errorEl   = document.getElementById('addError');
        errorEl.classList.add('hidden');
        errorEl.textContent = '';

        const firstName    = document.getElementById('add_firstName').value.trim();
        const lastName     = document.getElementById('add_lastName').value.trim();
        const grade        = parseInt(document.getElementById('add_grade').value);
        const team         = document.getElementById('add_team').value;
        const email        = document.getElementById('add_email').value.trim();
        const phone        = document.getElementById('add_phone').value.trim();
        const parent1Name  = document.getElementById('add_parent1Name').value.trim();
        const parent1Phone = document.getElementById('add_parent1Phone').value.trim();
        const parent1Email = document.getElementById('add_parent1Email').value.trim();
        const eventGroup   = document.getElementById('add_eventGroup').value || null;
        const season       = [...document.querySelectorAll('input[name="add_season"]:checked')].map(i => i.value);

        if (!firstName || !lastName || !grade || !team || !email || !phone || !parent1Name || !parent1Phone || !parent1Email) {
          errorEl.textContent = 'Please fill in all required fields.';
          errorEl.classList.remove('hidden');
          return;
        }
        if (season.length === 0) {
          errorEl.textContent = 'Please select at least one season.';
          errorEl.classList.remove('hidden');
          return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

        const { error } = await supabase.from('registrations').insert([{
          athlete_type: 'New Athlete',
          first_name: firstName, last_name: lastName,
          grade, team, email, phone,
          season, event_group: eventGroup,
          parent1_name: parent1Name, parent1_phone: parent1Phone, parent1_email: parent1Email,
          middle_school: 'Other', is_specialty: false, has_activities: false,
        }]);

        if (error) {
          errorEl.textContent = error.message;
          errorEl.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-check"></i> Save Athlete';
          return;
        }

        // Refresh roster
        const { data: refreshed } = await supabase.from('registrations').select('*').order('last_name');
        allAthletes = refreshed || [];
        renderCards(allAthletes);
        document.getElementById('addModalOverlay').classList.add('hidden');

        // Reset form
        document.getElementById('addForm').querySelectorAll('input[type="text"], input[type="email"], input[type="tel"], select').forEach(el => el.value = '');
        document.querySelectorAll('input[name="add_season"]').forEach(c => c.checked = false);

        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Save Athlete';
      });

      // ── Import CSV ────────────────────────────────────────────────────────────
      const CSV_COLUMNS = [
        'first_name','last_name','grade','team','season','event_group',
        'email','phone','parent1_name','parent1_phone','parent1_email',
      ];

      const CSV_TEMPLATE_HEADERS = [
        'first_name','last_name','grade','team',
        'season (semicolon separated)','event_group',
        'email','phone','parent1_name','parent1_phone','parent1_email',
      ];

      document.getElementById('importBtn').addEventListener('click', () => {
        document.getElementById('importModalOverlay').classList.remove('hidden');
      });

      document.getElementById('downloadTemplateBtn').addEventListener('click', () => {
        const exampleRow = ['Jane','Smith','10','Girls','Cross Country; Outdoor Track & Field','Distance','jane@example.com','(555) 555-5555','Bob Smith','(555) 555-5556','bob@example.com'];
        const csv = [CSV_TEMPLATE_HEADERS, exampleRow]
          .map(row => row.map(v => `"${v}"`).join(','))
          .join('\n');
        const blob = new Blob([csv], { type: 'text/csv' });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url; a.download = 'jrtxctf-import-template.csv'; a.click();
        URL.revokeObjectURL(url);
      });

      // Drag and drop
      const uploadArea = document.getElementById('uploadArea');
      uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
      uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
      uploadArea.addEventListener('drop', e => {
        e.preventDefault();
        uploadArea.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) parseCSV(file);
      });

      document.getElementById('csvFileInput').addEventListener('change', e => {
        const file = e.target.files[0];
        if (file) parseCSV(file);
      });

      let parsedAthletes = [];

      function parseCSV(file) {
        const reader = new FileReader();
        reader.onload = (e) => {
          const lines  = e.target.result.split('\n').filter(l => l.trim());
          const headers = lines[0].split(',').map(h => h.replace(/"/g, '').trim().toLowerCase());
          const rows    = lines.slice(1);
          const errorEl = document.getElementById('importError');
          errorEl.classList.add('hidden');

          parsedAthletes = rows.map((row, i) => {
            const vals = row.match(/(".*?"|[^,]+)/g) || [];
            const clean = vals.map(v => v.replace(/^"|"$/g, '').trim());
            const obj = {};
            headers.forEach((h, idx) => { obj[h] = clean[idx] || ''; });

            // Normalise season column
            const seasonRaw = obj['season (semicolon separated)'] || obj['season'] || '';
            const season = seasonRaw.split(';').map(s => s.trim()).filter(Boolean);

            return {
              athlete_type:  'New Athlete',
              first_name:    obj.first_name,
              last_name:     obj.last_name,
              grade:         parseInt(obj.grade) || null,
              team:          obj.team,
              season,
              event_group:   obj.event_group || null,
              email:         obj.email,
              phone:         obj.phone,
              parent1_name:  obj.parent1_name,
              parent1_phone: obj.parent1_phone,
              parent1_email: obj.parent1_email,
              middle_school: 'Other',
              is_specialty:  false,
              has_activities: false,
            };
          }).filter(a => a.first_name && a.last_name);

          if (parsedAthletes.length === 0) {
            errorEl.textContent = 'No valid rows found. Check your CSV format matches the template.';
            errorEl.classList.remove('hidden');
            return;
          }

          showPreview(parsedAthletes);
        };
        reader.readAsText(file);
      }

      function showPreview(athletes) {
        const preview   = document.getElementById('importPreview');
        const countEl   = document.getElementById('previewCount');
        const table     = document.getElementById('previewTable');
        const saveBtn   = document.getElementById('importSaveBtn');

        countEl.textContent = `${athletes.length} athlete${athletes.length !== 1 ? 's' : ''} ready to import`;

        table.innerHTML = `
          <thead><tr>
            <th>Name</th><th>Grade</th><th>Team</th><th>Season(s)</th><th>Event</th><th>Email</th>
          </tr></thead>
          <tbody>
            ${athletes.map(a => `
              <tr>
                <td>${a.first_name} ${a.last_name}</td>
                <td>${a.grade || '—'}</td>
                <td>${a.team || '—'}</td>
                <td>${(a.season || []).join(', ') || '—'}</td>
                <td>${a.event_group || '—'}</td>
                <td>${a.email || '—'}</td>
              </tr>
            `).join('')}
          </tbody>
        `;

        preview.classList.remove('hidden');
        saveBtn.classList.remove('hidden');
        document.getElementById('uploadArea').classList.add('hidden');
      }

      window.clearImport = () => {
        parsedAthletes = [];
        document.getElementById('importPreview').classList.add('hidden');
        document.getElementById('importSaveBtn').classList.add('hidden');
        document.getElementById('uploadArea').classList.remove('hidden');
        document.getElementById('csvFileInput').value = '';
        document.getElementById('importError').classList.add('hidden');
      };

      document.getElementById('importSaveBtn').addEventListener('click', async () => {
        const btn     = document.getElementById('importSaveBtn');
        const errorEl = document.getElementById('importError');
        errorEl.classList.add('hidden');

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Importing...';

        const { error } = await supabase.from('registrations').insert(parsedAthletes);

        if (error) {
          errorEl.textContent = 'Import failed: ' + error.message;
          errorEl.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-file-arrow-up"></i> Import Athletes';
          return;
        }

        // Refresh roster
        const { data: refreshed } = await supabase.from('registrations').select('*').order('last_name');
        allAthletes = refreshed || [];
        renderCards(allAthletes);
        document.getElementById('importModalOverlay').classList.add('hidden');
        clearImport();

        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-file-arrow-up"></i> Import Athletes';
      });

      // ── Edit athlete ─────────────────────────────────────────────────────────
      window.openEditModal = (id) => {
        const a = allAthletes.find(x => x.id === id);
        if (!a) return;

        document.getElementById('edit_id').value         = a.id;
        document.getElementById('edit_firstName').value  = a.first_name || '';
        document.getElementById('edit_lastName').value   = a.last_name  || '';
        document.getElementById('edit_grade').value      = a.grade      || '';
        document.getElementById('edit_team').value       = a.team       || '';
        document.getElementById('edit_email').value      = a.email      || '';
        document.getElementById('edit_phone').value      = a.phone      || '';
        document.getElementById('edit_parent1Name').value  = a.parent1_name  || '';
        document.getElementById('edit_parent1Phone').value = a.parent1_phone || '';
        document.getElementById('edit_parent1Email').value = a.parent1_email || '';
        document.getElementById('edit_eventGroup').value   = a.event_group   || '';

        // Season checkboxes
        document.querySelectorAll('input[name="edit_season"]').forEach(cb => {
          cb.checked = (a.season || []).includes(cb.value);
        });

        document.getElementById('editModalOverlay').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      };

      document.getElementById('updateAthleteBtn').addEventListener('click', async () => {
        const btn     = document.getElementById('updateAthleteBtn');
        const errorEl = document.getElementById('editError');
        errorEl.classList.add('hidden');
        errorEl.textContent = '';

        const id           = document.getElementById('edit_id').value;
        const firstName    = document.getElementById('edit_firstName').value.trim();
        const lastName     = document.getElementById('edit_lastName').value.trim();
        const grade        = parseInt(document.getElementById('edit_grade').value);
        const team         = document.getElementById('edit_team').value;
        const email        = document.getElementById('edit_email').value.trim();
        const phone        = document.getElementById('edit_phone').value.trim();
        const parent1Name  = document.getElementById('edit_parent1Name').value.trim();
        const parent1Phone = document.getElementById('edit_parent1Phone').value.trim();
        const parent1Email = document.getElementById('edit_parent1Email').value.trim();
        const eventGroup   = document.getElementById('edit_eventGroup').value || null;
        const season       = [...document.querySelectorAll('input[name="edit_season"]:checked')].map(i => i.value);

        if (!firstName || !lastName || !grade || !team || !email || !phone || !parent1Name || !parent1Phone || !parent1Email) {
          errorEl.textContent = 'Please fill in all required fields.';
          errorEl.classList.remove('hidden');
          return;
        }
        if (season.length === 0) {
          errorEl.textContent = 'Please select at least one season.';
          errorEl.classList.remove('hidden');
          return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

        const { error } = await supabase
          .from('registrations')
          .update({
            first_name: firstName, last_name: lastName,
            grade, team, email, phone,
            season, event_group: eventGroup,
            parent1_name: parent1Name, parent1_phone: parent1Phone, parent1_email: parent1Email,
          })
          .eq('id', id);

        if (error) {
          errorEl.textContent = error.message;
          errorEl.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
          return;
        }

        // Refresh roster
        const { data: refreshed } = await supabase.from('registrations').select('*').order('last_name');
        allAthletes = refreshed || [];
        renderCards(allAthletes);
        document.getElementById('editModalOverlay').classList.add('hidden');
        document.body.style.overflow = '';

        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Changes';
      });

      // ── Export CSV ────────────────────────────────────────────────────────────
      document.getElementById('exportBtn').addEventListener('click', () => {
        const headers = [
          'Last Name','First Name','Grade','Birthday','Team','Season','Event Group',
          'Sprint Addons','Email','Phone','Middle School','Specialty Program',
          'Prior Activities','Parent 1 Name','Parent 1 Phone','Parent 1 Email',
          'Parent 2 Name','Parent 2 Phone','Parent 2 Email','Notes','Registered'
        ];

        const rows = allAthletes.map(a => [
          a.last_name, a.first_name, a.grade, a.birthday, a.team,
          (a.season || []).join('; '),
          a.event_group || '',
          (a.sprint_addons || []).join('; '),
          a.email, a.phone,
          a.middle_school === 'Other' ? a.other_middle_school : a.middle_school,
          a.specialty_program || '',
          (a.activities || []).join('; '),
          a.parent1_name, a.parent1_phone, a.parent1_email,
          a.parent2_name || '', a.parent2_phone || '', a.parent2_email || '',
          a.notes || '',
          new Date(a.created_at).toLocaleDateString()
        ]);

        const csv = [headers, ...rows]
          .map(row => row.map(v => `"${String(v).replace(/"/g, '""')}"`).join(','))
          .join('\n');

        const blob = new Blob([csv], { type: 'text/csv' });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = url;
        a.download = `jrtxctf-roster-${new Date().toISOString().split('T')[0]}.csv`;
        a.click();
        URL.revokeObjectURL(url);
      });

      })(); // end async IIFE
    </script>
  </body>
</html>

<style>
  :root {
    --navy:      #0033A0;
    --navy-dark: #002280;
    --orange:    #FF6700;
    --text:      #0f172a;
    --muted:     #64748b;
    --border:    #e2e8f0;
    --bg:        #f1f5f9;
    --white:     #ffffff;
    --sidebar-w: 220px;
    --font:      'DM Sans', system-ui, sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Layout ─────────────────────────────────────────────────────────────── */
  .layout {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ────────────────────────────────────────────────────────────── */
  .sidebar {
    width: var(--sidebar-w);
    background: var(--navy);
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 100;
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: white;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 0 0.5rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    margin-bottom: 1.5rem;
  }

  .sidebar-brand i { color: var(--orange); font-size: 1.2rem; }

  .sidebar-nav { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .nav-item:hover { background: rgba(255,255,255,0.1); color: white; }
  .nav-item.active { background: rgba(255,255,255,0.15); color: white; }
  .nav-item i { width: 16px; text-align: center; }

  .sidebar-footer {
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.6);
    font-size: 0.78rem;
    overflow: hidden;
  }

  .user-info span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .btn-signout {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    color: rgba(255,255,255,0.7);
    font-size: 0.82rem;
    font-family: var(--font);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-signout:hover { background: rgba(255,255,255,0.15); color: white; }

  /* ── Main ───────────────────────────────────────────────────────────────── */
  .main {
    margin-left: var(--sidebar-w);
    flex: 1;
    padding: 2rem 2.5rem;
    max-width: calc(100vw - var(--sidebar-w));
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .page-sub { color: var(--muted); font-size: 0.9rem; margin-top: 0.2rem; }

  .header-actions { display: flex; gap: 0.75rem; }

  .btn-export {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font);
    color: var(--text);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .btn-export:hover { border-color: var(--navy); color: var(--navy); }

  /* ── Filters ────────────────────────────────────────────────────────────── */
  .filters {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
    padding: 1.25rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 150px;
  }

  .search-group { flex: 1; min-width: 200px; }

  .filter-group label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
  }

  .filter-group select,
  .filter-group input {
    padding: 0.55rem 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 7px;
    font-size: 0.875rem;
    font-family: var(--font);
    color: var(--text);
    background: var(--bg);
    outline: none;
    transition: border-color 0.15s ease;
  }

  .filter-group select:focus,
  .filter-group input:focus { border-color: var(--orange); }

  .search-wrap { position: relative; }
  .search-wrap i {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 0.8rem;
  }
  .search-wrap input { width: 100%; padding-left: 2.2rem; }

  /* ── Roster table ───────────────────────────────────────────────────────── */
  .table-wrap {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    overflow-x: auto;
  }

  .roster-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    white-space: nowrap;
  }

  .roster-table thead {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .roster-table th {
    padding: 0.75rem 1rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    text-align: left;
  }

  .roster-table td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--bg);
    color: var(--text);
    vertical-align: middle;
  }

  .roster-table tbody tr:last-child td { border-bottom: none; }

  .roster-table tbody tr:hover { background: #f8fafc; }

  .name-cell {
    display: flex; align-items: center; gap: 0.65rem;
  }

  .athlete-avatar {
    width: 30px; height: 30px;
    background: var(--navy); color: white;
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; font-weight: 700; flex-shrink: 0;
  }

  .athlete-name-link {
    font-weight: 600; color: var(--navy);
    cursor: pointer; white-space: nowrap;
  }
  .athlete-name-link:hover { text-decoration: underline; }

  .contact-cell { color: var(--muted); font-size: 0.82rem; }
  .season-cell  { color: var(--muted); font-size: 0.82rem; max-width: 180px; white-space: normal; }

  .tag {
    font-size: 0.7rem; font-weight: 600;
    padding: 0.2rem 0.5rem; border-radius: 4px;
    text-transform: uppercase; letter-spacing: 0.5px;
    white-space: nowrap;
  }
  .tag-team.boys  { background: #dbeafe; color: #1d4ed8; }
  .tag-team.girls { background: #fce7f3; color: #be185d; }
  .tag-event      { background: #fff7ed; color: var(--orange); }

  .row-actions { display: flex; gap: 0.4rem; }

  .btn-row-view, .btn-row-edit {
    width: 30px; height: 30px;
    border-radius: 6px; border: 1.5px solid var(--border);
    background: var(--bg); cursor: pointer;
    font-size: 0.75rem; color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    transition: all 0.12s ease;
  }
  .btn-row-view:hover { border-color: var(--navy); color: var(--navy); background: #eff6ff; }
  .btn-row-edit:hover { border-color: var(--orange); color: var(--orange); background: #fff7ed; }

  .loading-cell { text-align: center; color: var(--muted); padding: 3rem; }

  /* ── States ─────────────────────────────────────────────────────────────── */
  .loading-state, .empty-state, .access-denied, .error-state {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 4rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .loading-state i, .empty-state i, .access-denied i { font-size: 2rem; opacity: 0.4; }
  .hidden { display: none !important; }

  /* ── Modal ──────────────────────────────────────────────────────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.5);
    backdrop-filter: blur(4px);
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .modal {
    background: var(--white);
    border-radius: 16px;
    padding: 2rem;
    width: 100%;
    max-width: 580px;
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--bg);
    border: none;
    border-radius: 6px;
    width: 32px;
    height: 32px;
    cursor: pointer;
    color: var(--muted);
    font-size: 0.9rem;
    transition: all 0.15s;
  }

  .modal-close:hover { background: var(--border); color: var(--text); }

  .modal-header {
    display: flex;
